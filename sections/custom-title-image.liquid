{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .title-image-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .title-image-header-{{ section.id }} .h2 {
    font-weight: bold;
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: clamp(2.4rem, 4vw, 3.6rem); /* Scales nicely on mobile/desktop */
  }

  .title-image-header-{{ section.id }} .rte {
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.6rem;
    line-height: 1.5;
  }

  .title-image-wrapper-{{ section.id }} {
    width: 100%;
    border-radius: var(--media-radius);
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .title-image-{{ section.id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Placeholder styling */
  .placeholder-svg-wrapper {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-svg-wrapper svg {
    width: 100%;
    height: 100%;
    max-width: 100px;
    max-height: 100px;
    fill: rgba(var(--color-foreground), 0.2);
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  
  {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
    <div class="title-image-header-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="h2">{{ section.settings.title }}</h2>
      {%- endif -%}
      
      {%- if section.settings.subtitle != blank -%}
        <div class="rte">
          {{ section.settings.subtitle }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="title-image-wrapper-{{ section.id }}">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: 
        class: 'title-image',
        loading: 'lazy',
        sizes: '100vw'
      }}
    {%- else -%}
      <div class="placeholder-svg-wrapper">
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      </div>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Title & Image Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Title & Image Banner"
    }
  ]
}
{% endschema %}