{{ 'section-how-it-works.css' | asset_url | stylesheet_tag }}

<section class="how-it-works" style="background-color: {{ section.settings.background_color }};">
  {% if section.settings.background_image != blank %}
    <div class="how-it-works__bg">
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        loading="lazy"
        class="how-it-works__bg-image"
      >
    </div>
  {% endif %}

  <div class="how-it-works__container page-width">
    {% if section.settings.heading != blank %}
      <div class="how-it-works__heading-wrapper">
        <h2 class="how-it-works__heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <div class="how-it-works__cards">
      {% for block in section.blocks %}
        <div class="how-it-works__card" {{ block.shopify_attributes }} style="background-color: {{ block.settings.card_bg }};">
          {% if block.settings.label != blank %}
            <span class="how-it-works__card-label" style="background-color: {{ block.settings.label_bg }};color: {{ block.settings.label_color }};">
              {{ block.settings.label }}
            </span>
          {% endif %}
          {% if block.settings.card_heading != blank %}
            <h3 class="how-it-works__card-heading" style="color: {{ block.settings.card_text_color }};">
              {{ block.settings.card_heading }}
            </h3>
          {% endif %}
          {% if block.settings.card_text != blank %}
            <p class="how-it-works__card-text" style="color: {{ block.settings.card_text_color }};">
              {{ block.settings.card_text }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section-how-it-works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e8f4e8"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "blocks": [
    {
      "type": "solution_card",
      "name": "Solution Card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Solution 1"
        },
        {
          "type": "color",
          "id": "label_bg",
          "label": "Label background",
          "default": "#333333"
        },
        {
          "type": "color",
          "id": "label_color",
          "label": "Label text color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "card_heading",
          "label": "Card heading",
          "default": "Instantly Eliminates Existing Sulfur Gas"
        },
        {
          "type": "textarea",
          "id": "card_text",
          "label": "Card description",
          "default": "(AKA Bad Breath)"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card background",
          "default": "#00994d"
        },
        {
          "type": "color",
          "id": "card_text_color",
          "label": "Card text color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "solution_card",
          "settings": {
            "label": "Solution 1",
            "card_heading": "Instantly Eliminates Existing Sulfur Gas",
            "card_text": "(AKA Bad Breath)",
            "card_bg": "#00994d"
          }
        },
        {
          "type": "solution_card",
          "settings": {
            "label": "Solution 2",
            "card_heading": "Activates Billions of Zinc Ions to Block Germs & Prevent New Bad Breath",
            "card_text": "",
            "card_bg": "#007a3d"
          }
        }
      ]
    }
  ]
}
{% endschema %}
