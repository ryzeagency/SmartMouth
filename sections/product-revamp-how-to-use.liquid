<section
  class="product-how-to product-how-to--card-{{ section.settings.card_position }}"
  aria-labelledby="ProductHowToHeading-{{ section.id }}"
>
  <div class="product-how-to__inner">
    <div class="product-how-to__card">
      {%- if section.settings.heading != blank -%}
        <h2 class="product-how-to__heading" id="ProductHowToHeading-{{ section.id }}">
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}

      {%- liquid
        assign visible_steps = 0
        for block in section.blocks
          if block.settings.heading != blank or block.settings.body != blank
            assign visible_steps = visible_steps | plus: 1
          endif
        endfor
      -%}

      {%- if visible_steps > 0 -%}
        <ol class="product-how-to__steps" role="list">
          {%- assign step_number = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.heading != blank or block.settings.body != blank -%}
              {%- assign step_number = step_number | plus: 1 -%}
              <li class="product-how-to__step" {{ block.shopify_attributes }}>
                <span class="product-how-to__number" aria-hidden="true">{{ step_number }}</span>
                <div class="product-how-to__step-content">
                  {%- if block.settings.heading != blank -%}
                    <h3>{{ block.settings.heading | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.body != blank -%}
                    <div class="product-how-to__step-body rte">{{ block.settings.body }}</div>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ol>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --product-body-size: 1vw;
    --product-body-size-mobile: 3.5vw;
    --product-how-to-background: {{ section.settings.background_color }};
    --product-how-to-text: {{ section.settings.text_color }};
    --product-how-to-number: {{ section.settings.number_background }};
    --product-how-to-number-text: {{ section.settings.number_text_color }};
    --product-how-to-card-width: {{ section.settings.card_width }}vw;
  }

  #shopify-section-{{ section.id }} .product-how-to {
    padding: 2.5vw 0;
    color: var(--product-how-to-text);
    background-color: var(--product-how-to-background);
    background-image: {% if section.settings.desktop_background != blank %}url('{{ section.settings.desktop_background | image_url: width: 3840 }}'){% else %}none{% endif %};
    background-repeat: no-repeat;
    background-position: {{ section.settings.desktop_background_position }};
    background-size: cover;
  }

  #shopify-section-{{ section.id }} .product-how-to__inner {
    display: flex;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .product-how-to--card-left .product-how-to__inner {
    justify-content: flex-start;
  }

  #shopify-section-{{ section.id }} .product-how-to--card-right .product-how-to__inner {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .product-how-to__card {
    width: var(--product-how-to-card-width);
    padding: 2.25vw 4.15vw 3.5vw;
    color: inherit;
    background: rgba(
      {{ section.settings.card_background.red }},
      {{ section.settings.card_background.green }},
      {{ section.settings.card_background.blue }},
      {{ section.settings.card_opacity | divided_by: 100.0 }}
    );
    border-radius: 0.55vw;
    backdrop-filter: blur(0.35vw);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .product-how-to__heading {
    margin: 0 0 2.2vw;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.45vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.05;
  }

  #shopify-section-{{ section.id }} .product-how-to__steps {
    display: grid;
    gap: 1.75vw;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .product-how-to__step {
    display: grid;
    grid-template-columns: 3vw minmax(0, 1fr);
    align-items: start;
    column-gap: 1.1vw;
  }

  #shopify-section-{{ section.id }} .product-how-to__number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3vw;
    aspect-ratio: 1;
    color: var(--product-how-to-number-text);
    background: var(--product-how-to-number);
    border-radius: 50%;
    font-family: var(--font-heading-family);
    font-size: 1.45vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .product-how-to__step-content {
    padding-top: 0.2vw;
  }

  #shopify-section-{{ section.id }} .product-how-to__step h3 {
    margin: 0 0 0.2vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.08vw;
    font-style: var(--font-body-style);
    font-weight: 700;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .product-how-to__step-body {
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--product-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .product-how-to__step-body p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .product-how-to {
      padding: {{ section.settings.mobile_padding_top }}vw 0 {{ section.settings.mobile_padding_bottom }}vw;
      background-image: {% if section.settings.mobile_background != blank %}url('{{ section.settings.mobile_background | image_url: width: 1600 }}'){% elsif section.settings.desktop_background != blank %}url('{{ section.settings.desktop_background | image_url: width: 1600 }}'){% else %}none{% endif %};
      background-position: {{ section.settings.mobile_background_position }};
    }

    #shopify-section-{{ section.id }} .product-how-to__card {
      width: 85vw;
      padding: 8vw 6vw 10vw;
      border-radius: 3vw;
      backdrop-filter: blur(1.2vw);
    }

    #shopify-section-{{ section.id }} .product-how-to__heading {
      margin-bottom: 8vw;
      font-size: 6vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__steps {
      gap: 7vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__step {
      grid-template-columns: 12vw minmax(0, 1fr);
      column-gap: 4vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__number {
      width: 12vw;
      font-size: 6vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__step-content {
      padding-top: 0.8vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__step h3 {
      margin-bottom: 1vw;
      font-size: 3.5vw;
    }

    #shopify-section-{{ section.id }} .product-how-to__step-body {
      font-size: var(--product-body-size-mobile);
      line-height: 1.45;
    }
  }
</style>

{% schema %}
{
  "name": "Product How To Use",
  "tag": "section",
  "class": "section section-product-revamp-how-to-use",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to use:"
    },
    {
      "type": "header",
      "content": "Desktop card"
    },
    {
      "type": "select",
      "id": "card_position",
      "label": "Card position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 40,
      "max": 60,
      "step": 1,
      "unit": "vw",
      "label": "Card width",
      "default": 48
    },
    {
      "type": "header",
      "content": "Background images"
    },
    {
      "type": "image_picker",
      "id": "desktop_background",
      "label": "Desktop background"
    },
    {
      "type": "select",
      "id": "desktop_background_position",
      "label": "Desktop image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "image_picker",
      "id": "mobile_background",
      "label": "Mobile background",
      "info": "Falls back to the desktop image when blank."
    },
    {
      "type": "select",
      "id": "mobile_background_position",
      "label": "Mobile image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "vw",
      "label": "Top spacing",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "vw",
      "label": "Bottom spacing",
      "default": 12
    },
    {
      "type": "header",
      "content": "Card colors"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#E6F2F4"
    },
    {
      "type": "range",
      "id": "card_opacity",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Card opacity",
      "default": 85
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#092847"
    },
    {
      "type": "color",
      "id": "number_background",
      "label": "Number background",
      "default": "#20588F"
    },
    {
      "type": "color",
      "id": "number_text_color",
      "label": "Number text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback",
      "default": "#DCEFF1"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Instruction step",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Pour the Sulfur Eliminator (green cap)"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Open the green cap and pour to the 10mL mark on the provided cup.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product How To Use",
      "category": "Product Revamp",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "heading": "Pour the Sulfur Eliminator (green cap)",
            "body": "<p>Open the green cap and pour to the 10mL mark on the provided cup.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Add the Zinc Activator (blue cap)",
            "body": "<p>Open the blue cap and pour to the 20mL mark in the same cup.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Swish for 30 seconds",
            "body": "<p>Rinse thoroughly for 30 seconds. Spit out — do not swallow. Do not eat or drink for 30 minutes after rinsing.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Repeat twice daily",
            "body": "<p>Morning and evening. Two rinses a day delivers 24-hour bad breath protection.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
