{% liquid
  assign section_label = section.settings.heading | default: section.settings.eyebrow | strip_html
%}

<section
  class="how-to-works how-to-works--{{ section.settings.card_position }}"
  aria-label="{{ section_label | escape }}"
>
  <div class="how-to-works__container">
    <div class="how-to-works__card">
      {% if section.settings.eyebrow != blank %}
        <p class="how-to-works__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="how-to-works__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.intro != blank %}
        <div class="how-to-works__intro rte">{{ section.settings.intro }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ol class="how-to-works__steps" role="list">
          {% for block in section.blocks %}
            <li class="how-to-works__step" {{ block.shopify_attributes }}>
              <span class="how-to-works__dot" aria-hidden="true"></span>
              <div class="how-to-works__step-copy">
                {% if block.settings.heading != blank %}
                  <h3 class="how-to-works__step-heading">{{ block.settings.heading | escape }}</h3>
                {% endif %}

                {% if block.settings.body != blank %}
                  <div class="how-to-works__step-body rte">{{ block.settings.body }}</div>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ol>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --how-to-body-size: 1vw;
    --how-to-glass-rgb: {{ section.settings.card_background.red }}, {{ section.settings.card_background.green }}, {{ section.settings.card_background.blue }};
    --how-to-glass-opacity: {{ section.settings.card_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .how-to-works {
    background-color: {{ section.settings.background_color }};
    background-image: {% if section.settings.desktop_background != blank %}url('{{ section.settings.desktop_background | image_url: width: 3840 }}'){% else %}none{% endif %};
    background-position: {{ section.settings.desktop_background_position }};
    background-repeat: no-repeat;
    background-size: cover;
    color: {{ section.settings.text_color }};
    padding-block: {{ section.settings.padding_top }}vw {{ section.settings.padding_bottom }}vw;
  }

  #shopify-section-{{ section.id }} .how-to-works__container {
    display: flex;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .how-to-works--left .how-to-works__container {
    justify-content: flex-start;
  }

  #shopify-section-{{ section.id }} .how-to-works--right .how-to-works__container {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .how-to-works__card {
    box-sizing: border-box;
    width: {{ section.settings.card_width }}vw;
    padding: 2.8vw 4vw 3.1vw;
    border: 0.05vw solid rgba(255, 255, 255, 0.14);
    border-radius: 0.55vw;
    background: rgba(var(--how-to-glass-rgb), var(--how-to-glass-opacity));
    box-shadow: 0 0.8vw 2.4vw rgba(5, 13, 52, 0.08);
    -webkit-backdrop-filter: blur({{ section.settings.blur_strength }}vw);
    backdrop-filter: blur({{ section.settings.blur_strength }}vw);
  }

  #shopify-section-{{ section.id }} .how-to-works__eyebrow {
    margin: 0 0 0.8vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.45vw;
    font-style: var(--font-body-style);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .how-to-works__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.55vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .how-to-works__intro,
  #shopify-section-{{ section.id }} .how-to-works__step-body {
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--how-to-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.28;
  }

  #shopify-section-{{ section.id }} .how-to-works__intro {
    margin-top: 1.15vw;
  }

  #shopify-section-{{ section.id }} .how-to-works__intro > *,
  #shopify-section-{{ section.id }} .how-to-works__step-body > * {
    margin-block: 0;
  }

  #shopify-section-{{ section.id }} .how-to-works__steps {
    display: grid;
    gap: 1.35vw;
    margin: 1.35vw 0 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .how-to-works__step {
    display: grid;
    grid-template-columns: 1vw minmax(0, 1fr);
    gap: 0.9vw;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .how-to-works__dot {
    width: 1vw;
    aspect-ratio: 1;
    margin-top: 0.08vw;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
  }

  #shopify-section-{{ section.id }} .how-to-works__step-heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.05vw;
    font-style: var(--font-body-style);
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .how-to-works__step-body {
    margin-top: 0.1vw;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --how-to-body-size: 4vw;
    }

    #shopify-section-{{ section.id }} .how-to-works {
      {% if section.settings.mobile_background != blank %}
        background-image: url('{{ section.settings.mobile_background | image_url: width: 1500 }}');
      {% endif %}
      background-position: {{ section.settings.mobile_background_position }};
      padding-block: {{ section.settings.mobile_padding_top }}vw {{ section.settings.mobile_padding_bottom }}vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__container {
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .how-to-works__card {
      width: 85vw;
      padding: 8vw 7vw;
      border-width: 0.2vw;
      border-radius: 2vw;
      box-shadow: 0 2vw 8vw rgba(5, 13, 52, 0.1);
    }

    #shopify-section-{{ section.id }} .how-to-works__eyebrow {
      margin-bottom: 2.5vw;
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__heading {
      font-size: 6.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__intro {
      margin-top: 4vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__steps {
      gap: 5vw;
      margin-top: 6vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__step {
      grid-template-columns: 4vw minmax(0, 1fr);
      gap: 3vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__dot {
      width: 4vw;
      margin-top: 0.35vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__step-heading {
      font-size: 4.2vw;
    }

    #shopify-section-{{ section.id }} .how-to-works__step-body {
      margin-top: 1vw;
    }
  }
</style>

{% schema %}
{
  "name": "How To How It Works",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "HOW IT WORKS, STEP BY STEP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Two rinses a day. 24 hours of fresh breath."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>SmartMouth™ works in two ways: elimination and prevention. Every time you pour.</p>"
    },
    {
      "type": "header",
      "content": "Background images"
    },
    {
      "type": "image_picker",
      "id": "desktop_background",
      "label": "Desktop background"
    },
    {
      "type": "select",
      "id": "desktop_background_position",
      "label": "Desktop image position",
      "default": "center center",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "mobile_background",
      "label": "Mobile background"
    },
    {
      "type": "select",
      "id": "mobile_background_position",
      "label": "Mobile image position",
      "default": "center center",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback",
      "default": "#55546F"
    },
    {
      "type": "header",
      "content": "Glass card"
    },
    {
      "type": "select",
      "id": "card_position",
      "label": "Card position",
      "default": "right",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 50,
      "max": 75,
      "step": 1,
      "unit": "vw",
      "label": "Desktop card width",
      "default": 62
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Glass tint",
      "default": "#A5A5C7"
    },
    {
      "type": "range",
      "id": "card_opacity",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Glass opacity",
      "default": 55
    },
    {
      "type": "range",
      "id": "blur_strength",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "vw",
      "label": "Blur strength",
      "default": 1.2
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Step dots",
      "default": "#D5CBFF"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop top spacing",
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop bottom spacing",
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "label": "Mobile top spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "label": "Mobile bottom spacing",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "You pour the two solutions together"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>SmartMouth™’s dual-chamber bottle keeps the Sulfur Eliminating Solution and the Zinc Ion Activating Solution completely separate until the moment you pour them into the cup.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To How It Works",
      "category": "How To Revamp",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step",
          "settings": {
            "heading": "A chemical reaction releases billions of zinc ions",
            "body": "<p>When the two solutions combine in the cup, a chemical reaction occurs that instantly activates billions of zinc ions. The solution turns green — that’s your signal that it’s freshly activated and ready to work.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "The Sulfur Eliminator destroys existing bad breath",
            "body": "<p>The Sulfur Eliminating Solution immediately destroys any sulfur gas already present in your mouth — giving you instant fresh breath from the first rinse.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Zinc ions block germs from producing more",
            "body": "<p>The billions of activated zinc ions bond to the germs in your mouth and prevent them from consuming protein particles. No protein consumption means no sulfur gas production — and no bad breath returning for 12 hours per rinse, 24 hours with two rinses a day.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
