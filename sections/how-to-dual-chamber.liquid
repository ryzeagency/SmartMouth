{% liquid
  assign chamber_image = section.settings.desktop_illustration
  if chamber_image == blank
    assign chamber_image = section.settings.mobile_illustration
  endif
%}

<section class="how-to-chamber" aria-labelledby="HowToChamberHeading-{{ section.id }}">
  <div class="how-to-chamber__container">
    <header class="how-to-chamber__header">
      {% if section.settings.eyebrow != blank %}
        <p class="how-to-chamber__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="HowToChamberHeading-{{ section.id }}" class="how-to-chamber__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}
    </header>

    <div class="how-to-chamber__stage">
      {% for block in section.blocks %}
        <article
          class="how-to-chamber__solution how-to-chamber__solution--{{ block.settings.side }}"
          style="--solution-background: {{ block.settings.background_color }}; --solution-text: {{ block.settings.text_color }}; --virus-width: {{ block.settings.virus_width }}vw;"
          {{ block.shopify_attributes }}
        >
          <div class="how-to-chamber__solution-inner">
            {% if block.settings.side == 'green' and block.settings.virus_image != blank %}
              <div class="how-to-chamber__virus">
                {{
                  block.settings.virus_image
                  | image_url: width: 500
                  | image_tag:
                    widths: '150, 250, 350, 500',
                    sizes: '(min-width: 750px) 6vw, 18vw',
                    loading: 'lazy',
                    alt: block.settings.virus_alt
                }}
              </div>
            {% endif %}

            <div class="how-to-chamber__solution-copy">
              {% if block.settings.heading != blank %}
                <h3 class="how-to-chamber__solution-heading">{{ block.settings.heading | escape }}</h3>
              {% endif %}

              {% if block.settings.body != blank %}
                <div class="how-to-chamber__solution-body rte">{{ block.settings.body }}</div>
              {% endif %}
            </div>

            {% if block.settings.side == 'blue' and block.settings.virus_image != blank %}
              <div class="how-to-chamber__virus">
                {{
                  block.settings.virus_image
                  | image_url: width: 500
                  | image_tag:
                    widths: '150, 250, 350, 500',
                    sizes: '(min-width: 750px) 6vw, 18vw',
                    loading: 'lazy',
                    alt: block.settings.virus_alt
                }}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}

      {% if chamber_image != blank %}
        <picture class="how-to-chamber__illustration">
          {% if section.settings.mobile_illustration != blank %}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.mobile_illustration | image_url: width: 1500 }}"
            >
          {% endif %}
          {{
            chamber_image
            | image_url: width: 2400
            | image_tag:
              widths: '700, 1000, 1400, 1800, 2400',
              sizes: '(min-width: 750px) 32vw, 85vw',
              loading: 'lazy',
              alt: section.settings.illustration_alt
          }}
        </picture>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --how-to-body-size: 1vw;
  }

  #shopify-section-{{ section.id }} .how-to-chamber {
    overflow: hidden;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-block: {{ section.settings.padding_top }}vw {{ section.settings.padding_bottom }}vw;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__container {
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__header {
    max-width: 69vw;
    margin-inline: auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__eyebrow {
    margin: 0 0 1.2vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.45vw;
    font-style: var(--font-body-style);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.55vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__stage {
    position: relative;
    z-index: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 78vw;
    margin: 5.6vw auto 0;
    padding-bottom: 19vw;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    min-width: 0;
    padding-block: 2vw;
    border-radius: 0.45vw;
    background: var(--solution-background);
    color: var(--solution-text);
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution--blue {
    order: 1;
    padding-inline: 3vw 8vw;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution--green {
    order: 3;
    padding-inline: 8vw 3vw;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1vw;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution-copy {
    flex: 1 1 auto;
    min-width: 0;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution-heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.05vw;
    font-style: var(--font-body-style);
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution-body {
    margin-top: 0.2vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--how-to-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__solution-body > * {
    margin-block: 0;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__virus {
    flex: 0 0 var(--virus-width);
    width: var(--virus-width);
  }

  #shopify-section-{{ section.id }} .how-to-chamber__virus img {
    display: block;
    width: 100%;
    height: auto;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__illustration {
    position: absolute;
    top: -2.5vw;
    left: 50%;
    z-index: 2;
    display: block;
    width: {{ section.settings.desktop_image_width }}vw;
    transform: translateX(-50%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .how-to-chamber__illustration img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --how-to-body-size: 4vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber {
      padding-block: {{ section.settings.mobile_padding_top }}vw {{ section.settings.mobile_padding_bottom }}vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__header {
      max-width: none;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__eyebrow {
      margin-bottom: 3vw;
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__heading {
      font-size: 6.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__stage {
      display: flex;
      flex-direction: column;
      width: 85vw;
      margin-top: 10vw;
      padding-bottom: 0;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution {
      width: 100%;
      padding: 7vw;
      border-radius: 2vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution--blue {
      order: 1;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution--green {
      order: 3;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution-inner {
      gap: 4vw;
      flex-direction: column-reverse;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution-heading {
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__solution-body {
      margin-top: 1vw;
    }

    #shopify-section-{{ section.id }} .how-to-chamber__virus {
      flex-basis: calc(var(--virus-width) + 8vw);
      width: calc(var(--virus-width) + 8vw);
    }

    #shopify-section-{{ section.id }} .how-to-chamber__illustration {
      position: relative;
      top: auto;
      left: auto;
      order: 2;
      width: {{ section.settings.mobile_image_width }}vw;
      margin: -5vw auto;
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "How To Dual Chamber",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE DUAL-CHAMBER BOTTLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Scientifically designed to keep the power of zinc ion activation in your hands — every pour."
    },
    {
      "type": "header",
      "content": "Bottle and arrows image"
    },
    {
      "type": "image_picker",
      "id": "desktop_illustration",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_illustration",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "illustration_alt",
      "label": "Image alt text",
      "default": "SmartMouth dual-chamber bottle pouring both solutions"
    },
    {
      "type": "range",
      "id": "desktop_image_width",
      "min": 20,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "label": "Desktop image width",
      "default": 29
    },
    {
      "type": "range",
      "id": "mobile_image_width",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vw",
      "label": "Mobile image width",
      "default": 85
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text",
      "default": "#06264A"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop top spacing",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop bottom spacing",
      "default": 1
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "vw",
      "label": "Mobile top spacing",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "vw",
      "label": "Mobile bottom spacing",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "solution",
      "name": "Solution box",
      "settings": [
        {
          "type": "select",
          "id": "side",
          "label": "Solution color",
          "default": "blue",
          "options": [
            { "value": "blue", "label": "Blue" },
            { "value": "green", "label": "Green" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Zinc Rich Activator (blue cap)"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Releases billions of zinc ions when poured — bonds to germs and prevents sulfur gas production for 12 hours per rinse.</p>"
        },
        {
          "type": "image_picker",
          "id": "virus_image",
          "label": "Virus image"
        },
        {
          "type": "text",
          "id": "virus_alt",
          "label": "Virus image alt text",
          "default": "Solution molecule illustration"
        },
        {
          "type": "range",
          "id": "virus_width",
          "min": 2,
          "max": 8,
          "step": 0.5,
          "unit": "vw",
          "label": "Virus width",
          "default": 4
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Box background",
          "default": "#285B91"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Box text",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To Dual Chamber",
      "category": "How To Revamp",
      "blocks": [
        {
          "type": "solution"
        },
        {
          "type": "solution",
          "settings": {
            "side": "green",
            "heading": "Sulfur Eliminator (green cap)",
            "body": "<p>Destroys existing sulfur gas in your mouth on contact — instant fresh breath from the first rinse.</p>",
            "background_color": "#008641",
            "text_color": "#FFFFFF"
          }
        }
      ]
    }
  ]
}
{% endschema %}
