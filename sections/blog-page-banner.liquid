{% liquid
  assign banner_image = section.settings.desktop_image
  if banner_image == blank
    assign banner_image = section.settings.mobile_image
  endif
  assign banner_label = section.settings.title | default: section.settings.top_subtitle
%}

<section
  class="blog-page-banner blog-page-banner--horizontal-{{ section.settings.horizontal_alignment }} blog-page-banner--vertical-{{ section.settings.vertical_alignment }}"
  aria-label="{{ banner_label | escape }}"
>
  {% if banner_image != blank %}
    <picture class="blog-page-banner__media" aria-hidden="true">
      {% if section.settings.mobile_image != blank %}
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.mobile_image | image_url: width: 1500 }}"
        >
      {% endif %}
      {{
        banner_image
        | image_url: width: 3840
        | image_tag:
          widths: '750, 1100, 1500, 2000, 3000, 3840',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: ''
      }}
    </picture>
  {% endif %}

  <div class="blog-page-banner__container">
    <div class="blog-page-banner__content">
      {% if section.settings.top_subtitle != blank %}
        <p class="blog-page-banner__top-subtitle">{{ section.settings.top_subtitle | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 id="BlogBannerHeading-{{ section.id }}" class="blog-page-banner__title">
          {{ section.settings.title | escape }}
        </h1>
      {% endif %}

      {% if section.settings.bottom_subtitle != blank %}
        <p class="blog-page-banner__bottom-subtitle">{{ section.settings.bottom_subtitle | escape }}</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .blog-page-banner {
    position: relative;
    display: flex;
    box-sizing: border-box;
    min-height: {{ section.settings.desktop_height }}vw;
    overflow: hidden;
    background: {{ section.settings.background_color }};
    padding-block: 2vw;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__media {
    position: absolute;
    inset: 0;
    display: block;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.desktop_image_position }};
  }

  #shopify-section-{{ section.id }} .blog-page-banner__container {
    position: relative;
    z-index: 1;
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--vertical-top .blog-page-banner__container {
    justify-content: flex-start;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--vertical-center .blog-page-banner__container {
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--vertical-bottom .blog-page-banner__container {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--horizontal-left .blog-page-banner__container {
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--horizontal-center .blog-page-banner__container {
    align-items: center;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--horizontal-right .blog-page-banner__container {
    align-items: flex-end;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__content {
    width: {{ section.settings.content_width }}vw;
    max-width: 100%;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--horizontal-left .blog-page-banner__content {
    text-align: left;
  }

  #shopify-section-{{ section.id }} .blog-page-banner--horizontal-right .blog-page-banner__content {
    text-align: right;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__top-subtitle,
  #shopify-section-{{ section.id }} .blog-page-banner__bottom-subtitle {
    margin: 0;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__top-subtitle {
    margin-bottom: 0.85vw;
    color: {{ section.settings.top_subtitle_color }};
    font-size: {{ section.settings.top_subtitle_size }}vw;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .blog-page-banner__bottom-subtitle {
    margin-top: 0.85vw;
    color: {{ section.settings.bottom_subtitle_color }};
    font-size: {{ section.settings.bottom_subtitle_size }}vw;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .blog-page-banner {
      min-height: {{ section.settings.mobile_height }}vw;
      padding-block: 6vw;
    }

    #shopify-section-{{ section.id }} .blog-page-banner__media img {
      object-position: {{ section.settings.mobile_image_position }};
    }

    #shopify-section-{{ section.id }} .blog-page-banner__content {
      width: 85vw;
    }

    #shopify-section-{{ section.id }} .blog-page-banner__top-subtitle {
      margin-bottom: 3vw;
      font-size: {{ section.settings.mobile_top_subtitle_size }}vw;
    }

    #shopify-section-{{ section.id }} .blog-page-banner__title {
      font-size: {{ section.settings.mobile_title_size }}vw;
    }

    #shopify-section-{{ section.id }} .blog-page-banner__bottom-subtitle {
      margin-top: 3vw;
      font-size: {{ section.settings.mobile_bottom_subtitle_size }}vw;
    }
  }
</style>

{% schema %}
{
  "name": "Blog Page Banner V2",
  "tag": "section",
  "class": "section section-blog-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "top_subtitle",
      "label": "Top subtitle",
      "default": "THE BLOG"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The SmartMouth Journal"
    },
    {
      "type": "text",
      "id": "bottom_subtitle",
      "label": "Bottom subtitle",
      "default": "Science, oral health and the real story behind fresh breath."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "label": "Desktop banner height",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 50,
      "max": 150,
      "step": 1,
      "unit": "vw",
      "label": "Mobile banner height",
      "default": 90
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "label": "Desktop image position",
      "default": "center center",
      "options": [
        { "value": "left top", "label": "Top left" },
        { "value": "center top", "label": "Top center" },
        { "value": "right top", "label": "Top right" },
        { "value": "left center", "label": "Center left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Center right" },
        { "value": "left bottom", "label": "Bottom left" },
        { "value": "center bottom", "label": "Bottom center" },
        { "value": "right bottom", "label": "Bottom right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_image_position",
      "label": "Mobile image position",
      "default": "center center",
      "options": [
        { "value": "left top", "label": "Top left" },
        { "value": "center top", "label": "Top center" },
        { "value": "right top", "label": "Top right" },
        { "value": "left center", "label": "Center left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Center right" },
        { "value": "left bottom", "label": "Bottom left" },
        { "value": "center bottom", "label": "Bottom center" },
        { "value": "right bottom", "label": "Bottom right" }
      ]
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Content vertical position",
      "default": "center",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 30,
      "max": 85,
      "step": 1,
      "unit": "vw",
      "label": "Desktop content width",
      "default": 60
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback",
      "default": "#FFDD57"
    },
    {
      "type": "color",
      "id": "top_subtitle_color",
      "label": "Top subtitle color",
      "default": "#06264A"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#06264A"
    },
    {
      "type": "color",
      "id": "bottom_subtitle_color",
      "label": "Bottom subtitle color",
      "default": "#06264A"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "top_subtitle_size",
      "min": 0.6,
      "max": 2,
      "step": 0.1,
      "unit": "vw",
      "label": "Desktop top subtitle size",
      "default": 1
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 1.5,
      "max": 5,
      "step": 0.1,
      "unit": "vw",
      "label": "Desktop title size",
      "default": 2.6
    },
    {
      "type": "range",
      "id": "bottom_subtitle_size",
      "min": 0.6,
      "max": 2,
      "step": 0.1,
      "unit": "vw",
      "label": "Desktop bottom subtitle size",
      "default": 1
    },
    {
      "type": "range",
      "id": "mobile_top_subtitle_size",
      "min": 3,
      "max": 6,
      "step": 0.1,
      "unit": "vw",
      "label": "Mobile top subtitle size",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_title_size",
      "min": 6,
      "max": 12,
      "step": 0.1,
      "unit": "vw",
      "label": "Mobile title size",
      "default": 9
    },
    {
      "type": "range",
      "id": "mobile_bottom_subtitle_size",
      "min": 3,
      "max": 6,
      "step": 0.1,
      "unit": "vw",
      "label": "Mobile bottom subtitle size",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Blog Page Banner V2",
      "category": "Blog Revamp"
    }
  ]
}
{% endschema %}
