<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="testimonial-slider-section" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  
  {% if section.settings.heading != blank %}
    <h2 class="testimonial-slider__main-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="testimonial-slider__container">
    
    <div class="swiper swiper-testimonial-{{ section.id }}">
      <div class="swiper-wrapper">
        
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            
            <svg class="testimonial-slider__quote-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
              <path d="M448 224h-64v-24c0-30.9 25.1-56 56-56h16c22.1 0 40-17.9 40-40V72c0-22.1-17.9-40-40-40h-16c-92.6 0-168 75.4-168 168v216c0 35.3 28.7 64 64 64h112c35.3 0 64-28.7 64-64V288c0-35.3-28.7-64-64-64zm32 192c0 17.7-14.3 32-32 32H336c-17.7 0-32-14.3-32-32V200c0-75.1 60.9-136 136-136h16c4.4 0 8 3.6 8 8v32c0 4.4-3.6 8-8 8h-16c-48.6 0-88 39.4-88 88v56h96c17.7 0 32 14.3 32 32v128zM176 224h-64v-24c0-30.9 25.1-56 56-56h16c22.1 0 40-17.9 40-40V72c0-22.1-17.9-40-40-40h-16C75.4 32 0 107.4 0 200v216c0 35.3 28.7 64 64 64h112c35.3 0 64-28.7 64-64V288c0-35.3-28.7-64-64-64zm32 192c0 17.7-14.3 32-32 32H64c-17.7 0-32-14.3-32-32V200c0-75.1 60.9-136 136-136h16c4.4 0 8 3.6 8 8v32c0 4.4-3.6 8-8 8h-16c-48.6 0-88 39.4-88 88v56h96c17.7 0 32 14.3 32 32v128z"/>
            </svg>

            <div class="testimonial-slider__stars">
              {% for i in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
                  <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
                </svg>
              {% endfor %}
            </div>

            {% if block.settings.quote != blank %}
              <div class="testimonial-slider__text">
                {{ block.settings.quote }}
              </div>
            {% endif %}

            {% if block.settings.author != blank %}
              <cite class="testimonial-slider__author">— {{ block.settings.author }}</cite>
            {% endif %}

          </div>
        {% endfor %}

      </div>
      
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>

    </div>

  </div>

  {% if section.settings.button_label != blank %}
    <div class="testimonial-slider__btn-wrapper">
      <a 
        href="{{ section.settings.button_url }}" 
        class="testimonial-slider__btn"
        style="background-color: {{ section.settings.button_bg }}; color: {{ section.settings.button_text }};"
      >
        {{ section.settings.button_label }}
      </a>
    </div>
  {% endif %}

</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const swiper = new Swiper('.swiper-testimonial-{{ section.id }}', {
      loop: true,
      autoHeight: true,
      spaceBetween: 30,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: true,
      },
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "tag": "section",
  "class": "section-testimonial-slider",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#006bba"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What People Are Saying About SmartMouth™"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "READ MORE REVIEWS"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background Color",
      "default": "#008035"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text",
          "default": "I love SmartMouth and have been using it for years. As a cigar smoker, it’s important to know that this fantastic mouthwash exists. Now they’ve improved their dispensing system. Awesome family owned company, which I love supporting."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Alan"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I just want to say thank you for this amazing product. For years I have struggled with dry mouth due to my autoimmune disease. In just 24 hours, I saw a major improvement. Now I feel confident in pursuing my dreams. Your products are truly a lifesaver. I will be a customer for life!",
            "author": "Nikia"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I love SmartMouth and have been using it for years. As a cigar smoker, it’s important to know that this fantastic mouthwash exists. Now they’ve improved their dispensing system. Awesome family owned company, which I love supporting.",
            "author": "Alan"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "You win… I tried to not have fresh breath after rinsing with SmartMouth by eating garlic, onions, fermented beans, pepperoni, and coffee. But my breath was fresh again after an hour of eating those things. I am a fan for life.",
            "author": "Mika"
          }
        }
      ]
    }
  ]
}
{% endschema %}