{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

<section class="testimonials" style="background-color: {{ section.settings.background_color }};">
  <div class="testimonials__container page-width">
    {% if section.settings.heading != blank %}
      <h2 class="testimonials__heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.show_stars %}
      <div class="testimonials__stars">
        {% for i in (1..5) %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        {% endfor %}
      </div>
    {% endif %}

    <div class="testimonials__slider" id="testimonials-slider">
      {% for block in section.blocks %}
        <div class="testimonials__slide {% if forloop.first %}testimonials__slide--active{% endif %}" data-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {% if block.settings.quote != blank %}
            <blockquote class="testimonials__quote" style="color: {{ section.settings.text_color }};">
              "{{ block.settings.quote }}"
            </blockquote>
          {% endif %}
          {% if block.settings.author != blank %}
            <cite class="testimonials__author" style="color: {{ section.settings.text_color }};">
              — {{ block.settings.author }}
            </cite>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="testimonials__nav">
        <button class="testimonials__arrow testimonials__arrow--prev" aria-label="Previous testimonial" style="color: {{ section.settings.text_color }};">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="testimonials__dots">
          {% for block in section.blocks %}
            <button class="testimonials__dot {% if forloop.first %}testimonials__dot--active{% endif %}" data-dot="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}" style="background-color: {{ section.settings.text_color }};"></button>
          {% endfor %}
        </div>
        <button class="testimonials__arrow testimonials__arrow--next" aria-label="Next testimonial" style="color: {{ section.settings.text_color }};">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {% endif %}

    {% if section.settings.reviews_button_label != blank %}
      <div class="testimonials__cta">
        <a
          href="{{ section.settings.reviews_button_url }}"
          class="testimonials__cta-btn"
          style="background-color: {{ section.settings.button_bg }};color: {{ section.settings.button_text_color }};"
        >
          {{ section.settings.reviews_button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function() {
    const slider = document.getElementById('testimonials-slider');
    if (!slider) return;
    const section = slider.closest('.testimonials');
    const slides = slider.querySelectorAll('.testimonials__slide');
    const dots = section.querySelectorAll('.testimonials__dot');
    const prevBtn = section.querySelector('.testimonials__arrow--prev');
    const nextBtn = section.querySelector('.testimonials__arrow--next');
    let current = 0;
    const total = slides.length;

    function goTo(index) {
      slides[current].classList.remove('testimonials__slide--active');
      if (dots[current]) dots[current].classList.remove('testimonials__dot--active');
      current = (index + total) % total;
      slides[current].classList.add('testimonials__slide--active');
      if (dots[current]) dots[current].classList.add('testimonials__dot--active');
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() { goTo(parseInt(this.dataset.dot)); });
    });

    // Auto-rotate
    let autoplay = setInterval(function() { goTo(current + 1); }, 6000);
    section.addEventListener('mouseenter', function() { clearInterval(autoplay); });
    section.addEventListener('mouseleave', function() {
      autoplay = setInterval(function() { goTo(current + 1); }, 6000);
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What People Are Saying About SmartMouth™"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a8c3a"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFD700"
    },
    {
      "type": "text",
      "id": "reviews_button_label",
