<div class="custom-product-info" id="custom-info-{{ section.id }}">
  
  <div class="cpi-section cpi-bg-blue">
    <div class="cpi-container">
      <div class="cpi-content">
        {% if section.settings.p1_title != blank %}
          <h2 class="cpi-heading">{{ section.settings.p1_title }}</h2>
        {% endif %}
        {% if section.settings.p1_text != blank %}
          <div class="cpi-text">{{ section.settings.p1_text }}</div>
        {% endif %}
      </div>
      <div class="cpi-image">
        {% if section.settings.p1_image %}
          {{ section.settings.p1_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.p1_title }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>

  <div class="cpi-section cpi-full-image">
    {% if section.settings.p2_image %}
      {{ section.settings.p2_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'cpi-banner-img', alt: 'How it works' }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg cpi-banner-img' }}
    {% endif %}
  </div>

  <div class="cpi-section cpi-bg-white">
    <div class="cpi-container">
      <div class="cpi-image">
        {% if section.settings.p3_image %}
          {{ section.settings.p3_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.p3_title }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="cpi-content">
        {% if section.settings.p3_title != blank %}
          <h2 class="cpi-heading cpi-dark-text">{{ section.settings.p3_title }}</h2>
        {% endif %}
        {% if section.settings.p3_text != blank %}
          <div class="cpi-text cpi-dark-text">{{ section.settings.p3_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>

</div>

<style>
  #custom-info-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    font-family: inherit;
  }
  
  .cpi-section {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cpi-bg-blue {
    background-color: #0d71bd; /* Matches mockup blue */
    color: #ffffff;
    padding: 60px 20px;
  }

  .cpi-bg-white {
    background-color: #ffffff;
    color: #333333;
    padding: 60px 20px;
  }

  .cpi-container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .cpi-content, .cpi-image {
    flex: 1;
    width: 50%;
  }

  .cpi-heading {
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 20px;
    color: inherit;
  }

  .cpi-bg-blue .cpi-heading {
    color: #ffffff;
  }

  .cpi-text p {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 15px;
    color: inherit;
  }

  .cpi-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .cpi-full-image {
    width: 100%;
    background-color: #cce5ef; /* Fallback light blue */
  }

  .cpi-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .placeholder-svg {
    background-color: #f4f4f4;
    width: 100%;
    height: 400px;
  }

  /* Responsive styling */
  @media screen and (max-width: 768px) {
    .cpi-container {
      flex-direction: column;
      text-align: center;
      gap: 30px;
    }
    
    /* Ensure image goes below text on mobile for Part 1, but keeps Image above text for Part 3 */
    .cpi-bg-blue .cpi-container {
      flex-direction: column;
    }

    .cpi-content, .cpi-image {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Mouthwash Product Info",
  "settings": [
    {
      "type": "header",
      "content": "Part 1: The Science Behind"
    },
    {
      "type": "text",
      "id": "p1_title",
      "label": "Heading",
      "default": "The Science Behind Fresh Breath"
    },
    {
      "type": "richtext",
      "id": "p1_text",
      "label": "Text",
      "default": "<p>SmartMouth™ is not your ordinary mouthwash for bad breath. What sets it apart is our patented zinc ion technology...</p>"
    },
    {
      "type": "image_picker",
      "id": "p1_image",
      "label": "Image (Right Side)"
    },
    {
      "type": "header",
      "content": "Part 2: How It Works"
    },
    {
      "type": "image_picker",
      "id": "p2_image",
      "label": "Full Width Banner Image"
    },
    {
      "type": "header",
      "content": "Part 3: Fresh Breath That Lasts"
    },
    {
      "type": "image_picker",
      "id": "p3_image",
      "label": "Image (Left Side)"
    },
    {
      "type": "text",
      "id": "p3_title",
      "label": "Heading",
      "default": "Fresh Breath That Lasts"
    },
    {
      "type": "richtext",
      "id": "p3_text",
      "label": "Text",
      "default": "<p>Our commitment to innovation and quality means you're getting a product that's been carefully crafted to meet your needs...</p>"
    }
  ],
  "presets": [
    {
      "name": "Mouthwash Product Info",
      "category": "Product"
    }
  ]
}
{% endschema %}