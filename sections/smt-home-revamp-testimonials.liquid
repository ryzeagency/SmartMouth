<section
  class="hr-testimonials"
  data-testimonials-section="{{ section.id }}"
  data-testimonials-autoplay="{{ section.settings.enable_autoplay }}"
  data-testimonials-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
  aria-labelledby="TestimonialsHeading-{{ section.id }}"
>
  <header class="hr-testimonials__header">
    <h2 class="hr-testimonials__heading" id="TestimonialsHeading-{{ section.id }}">
      <span class="hr-testimonials__heading-line hr-testimonials__heading-line--top">
        {{ section.settings.heading_top | escape }}
      </span>
      <span class="hr-testimonials__heading-line hr-testimonials__heading-line--bottom">
        {{ section.settings.heading_bottom | escape }}
      </span>
    </h2>
  </header>

  <div
    class="hr-testimonials__viewport"
    data-testimonials-viewport
    role="region"
    aria-label="{{ section.settings.slider_label | escape }}"
    tabindex="0"
  >
    <div class="hr-testimonials__track" data-testimonials-track role="list">
      {% for block in section.blocks %}
        <article
          class="hr-testimonials__slide"
          data-testimonial-slide
          role="listitem"
          {{ block.shopify_attributes }}
        >
          <div
            class="hr-testimonials__card"
            style="--testimonial-card-bg: {{ block.settings.background_color }};"
          >
            <div
              class="hr-testimonials__stars"
              aria-label="{{ block.settings.rating }} out of 5 stars"
            >
              {%- if section.settings.stars_image != blank -%}
                <img
                  class="hr-testimonials__stars-image"
                  src="{{ section.settings.stars_image | image_url: width: 600 }}"
                  srcset="
                    {{ section.settings.stars_image | image_url: width: 200 }} 200w,
                    {{ section.settings.stars_image | image_url: width: 400 }} 400w,
                    {{ section.settings.stars_image | image_url: width: 600 }} 600w
                  "
                  sizes="(min-width: 750px) {{ section.settings.stars_image_width }}vw, 35vw"
                  width="{{ section.settings.stars_image.width }}"
                  height="{{ section.settings.stars_image.height }}"
                  alt=""
                  loading="lazy"
                >
              {%- else -%}
                <span aria-hidden="true">
                  {% for star in (1..5) %}
                    <span class="hr-testimonials__star{% if star > block.settings.rating %} hr-testimonials__star--empty{% endif %}">★</span>
                  {% endfor %}
                </span>
              {%- endif -%}
            </div>

            {% if block.settings.quote != blank %}
              <blockquote class="hr-testimonials__quote">
                <p>“{{ block.settings.quote | escape }}”</p>
              </blockquote>
            {% endif %}

            <footer class="hr-testimonials__author">
              {% if block.settings.author != blank %}
                <strong>{{ block.settings.author | escape }}</strong>
              {% endif %}
              {% if block.settings.author_label != blank %}
                <span>{{ block.settings.author_label | escape }}</span>
              {% endif %}
            </footer>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --hr-testimonials-bg: {{ section.settings.background_color }};
    --hr-testimonials-blue: {{ section.settings.heading_background }};
    --hr-testimonials-top-text: {{ section.settings.heading_top_color }};
    --hr-testimonials-bottom-text: {{ section.settings.heading_bottom_color }};
    --hr-testimonials-card-text: {{ section.settings.text_color }};
    --hr-testimonials-border: {{ section.settings.border_color }};
    --hr-testimonials-stars: {{ section.settings.star_color }};
    --hr-testimonials-stars-image-width: {{ section.settings.stars_image_width }}vw;
    --hr-testimonials-card-width: {{ section.settings.card_width }}vw;
    --hr-testimonials-gap: {{ section.settings.card_gap }}vw;
  }

  #shopify-section-{{ section.id }} .hr-testimonials {
    width: 100%;
    overflow: hidden;
    padding: 4vw 0 3.4vw;
    color: var(--hr-testimonials-card-text);
    background: var(--hr-testimonials-bg);
  }

  #shopify-section-{{ section.id }} .hr-testimonials__header {
    position: relative;
    z-index: 2;
    margin-bottom: 2.6vw;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__heading {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.1;
    transform: rotate(-2deg);
  }

  #shopify-section-{{ section.id }} .hr-testimonials__heading-line {
    display: block;
    background: var(--hr-testimonials-blue);
  }

  #shopify-section-{{ section.id }} .hr-testimonials__heading-line--top {
    z-index: 1;
    padding: .3vw 2.15vw .65vw;
    color: var(--hr-testimonials-top-text);
    font-size: 4.65vw;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__heading-line--bottom {
    margin-top: -.42vw;
    padding: .18vw 2.35vw .65vw;
    color: var(--hr-testimonials-bottom-text);
    font-size: 4.4vw;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__viewport {
    width: 100vw;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
    touch-action: pan-x;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__viewport::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__viewport.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
    user-select: none;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__viewport.is-teleporting {
    scroll-behavior: auto;
    scroll-snap-type: none;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__track {
    display: flex;
    align-items: stretch;
    gap: var(--hr-testimonials-gap);
    width: max-content;
    padding: 0 calc((100vw - var(--hr-testimonials-card-width)) / 2);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__slide {
    display: flex;
    flex: 0 0 var(--hr-testimonials-card-width);
    width: var(--hr-testimonials-card-width);
    padding-bottom: 3.9vw;
    scroll-snap-align: center;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__card {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 2.55vw 3vw 1.55vw;
    color: var(--hr-testimonials-card-text);
    background: var(--testimonial-card-bg);
    border: .2vw solid var(--hr-testimonials-border);
    border-radius: 1.2vw;
    text-align: center;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__card::after {
    content: '';
    position: absolute;
    right: 50%;
    bottom: -2.78vw;
    z-index: 0;
    width: 5.3vw;
    aspect-ratio: 1;
    background: var(--testimonial-card-bg);
    border-right: .2vw solid var(--hr-testimonials-border);
    border-bottom: .2vw solid var(--hr-testimonials-border);
    transform: translateX(50%) rotate(45deg);
  }

  #shopify-section-{{ section.id }} .hr-testimonials__stars,
  #shopify-section-{{ section.id }} .hr-testimonials__quote,
  #shopify-section-{{ section.id }} .hr-testimonials__author {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__stars {
    margin-bottom: .8vw;
    color: var(--hr-testimonials-stars);
    font-size: 2vw;
    letter-spacing: .12vw;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__star--empty {
    opacity: .25;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__stars-image {
    display: block;
    width: min(var(--hr-testimonials-stars-image-width), 100%);
    max-width: 100%;
    margin: 0 auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__quote {
    max-width: 26vw;
    margin: 0;
    padding: 0;
    color: inherit;
    border: 0;
    font-size: 1.13vw;
    font-style: italic;
    font-weight: 400;
    line-height: 1.28;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__quote p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__author {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: auto;
    padding-top: 1.25vw;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__author strong {
    font-size: 1.12vw;
    line-height: 1.15;
  }

  #shopify-section-{{ section.id }} .hr-testimonials__author span {
    margin-top: .15vw;
    color: inherit;
    font-size: .9vw;
    line-height: 1.15;
    opacity: .52;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --hr-testimonials-card-width: 85vw;
      --hr-testimonials-gap: 5vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials {
      padding: 12vw 0 10vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__header {
      margin-bottom: 10vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__heading-line--top {
      padding: 1.2vw 5vw 2vw;
      font-size: 8vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__heading-line--bottom {
      margin-top: -1vw;
      padding: 1vw 6vw 2.2vw;
      font-size: 8vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__slide {
      padding-bottom: 11vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__card {
      padding: 8vw 7vw 5vw;
      border-width: .7vw;
      border-radius: 4vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__card::after {
      bottom: -7.5vw;
      width: 15vw;
      border-right-width: .7vw;
      border-bottom-width: .7vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__stars {
      margin-bottom: 4vw;
      font-size: 7vw;
      letter-spacing: .4vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__stars-image {
      width: min(35vw, 100%);
    }

    #shopify-section-{{ section.id }} .hr-testimonials__quote {
      max-width: none;
      font-size: 3.5vw;
      line-height: 1.35;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__author {
      padding-top: 7vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__author strong {
      font-size: 4.3vw;
    }

    #shopify-section-{{ section.id }} .hr-testimonials__author span {
      margin-top: .6vw;
      font-size: 3.6vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .hr-testimonials__viewport {
      scroll-behavior: auto;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('[data-testimonials-section="{{ section.id }}"]');
    const viewport = section?.querySelector('[data-testimonials-viewport]');
    const track = section?.querySelector('[data-testimonials-track]');

    if (!section || !viewport || !track || viewport.dataset.sliderReady === 'true') return;

    viewport.dataset.sliderReady = 'true';

    const realSlides = Array.from(track.querySelectorAll('[data-testimonial-slide]'));
    const realCount = realSlides.length;

    if (realCount === 0) return;

    const loopEnabled = realCount > 1;

    /* ------------------------------------------------------------------
       Seamless loop: clone the full set of slides once before and once
       after the real set. When the scroll position drifts into a clone
       zone, we silently teleport it back by exactly one "set width", so
       there is always another card on both sides — no empty space at the
       start or end, and no visible rewind when autoplay wraps around.
    ------------------------------------------------------------------ */
    const makeClone = (slide) => {
      const clone = slide.cloneNode(true);
      clone.removeAttribute('data-testimonial-slide');
      clone.setAttribute('data-testimonial-clone', '');
      clone.setAttribute('aria-hidden', 'true');
      clone.setAttribute('role', 'presentation');
      clone.querySelectorAll('[id]').forEach((el) => el.removeAttribute('id'));
      clone.querySelectorAll('a, button, [tabindex]').forEach((el) => el.setAttribute('tabindex', '-1'));
      return clone;
    };

    if (loopEnabled) {
      track.prepend(...realSlides.map(makeClone));
      track.append(...realSlides.map(makeClone));
    }

    const allSlides = Array.from(track.children);
    const firstRealIndex = loopEnabled ? realCount : 0;

    const requestedIndex = {{ section.settings.initial_slide | minus: 1 }};
    const initialIndex = firstRealIndex + Math.max(0, Math.min(requestedIndex, realCount - 1));
    const autoplayEnabled = section.dataset.testimonialsAutoplay === 'true' && loopEnabled;
    const autoplayInterval = Number(section.dataset.testimonialsInterval) || 3000;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    let autoplayTimer = null;
    let settleTimer = null;
    let isDragging = false;
    let isPointerInside = false;
    let startX = 0;
    let startScrollLeft = 0;

    const centerLeftOf = (slide) =>
      slide.offsetLeft - ((viewport.clientWidth - slide.offsetWidth) / 2);

    const setWidth = () =>
      loopEnabled ? allSlides[realCount].offsetLeft - allSlides[0].offsetLeft : 0;

    const closestSlideIndex = () => {
      const viewportCenter = viewport.scrollLeft + (viewport.clientWidth / 2);

      return allSlides.reduce((closestIndex, slide, index) => {
        const slideCenter = slide.offsetLeft + (slide.offsetWidth / 2);
        const closestCenter = allSlides[closestIndex].offsetLeft + (allSlides[closestIndex].offsetWidth / 2);

        return Math.abs(slideCenter - viewportCenter) < Math.abs(closestCenter - viewportCenter)
          ? index
          : closestIndex;
      }, 0);
    };

    const teleportTo = (left) => {
      viewport.classList.add('is-teleporting');
      viewport.scrollLeft = left;
      // Force the style change to apply before restoring smooth scrolling.
      void viewport.offsetWidth;
      viewport.classList.remove('is-teleporting');
    };

    /* If we've settled inside a clone zone, jump back into the real set. */
    const normalize = () => {
      if (!loopEnabled || isDragging) return;

      const width = setWidth();
      if (!width) return;

      const min = centerLeftOf(allSlides[firstRealIndex]);
      const max = centerLeftOf(allSlides[firstRealIndex + realCount - 1]);
      const current = viewport.scrollLeft;

      if (current < min - 1) {
        teleportTo(current + width);
      } else if (current > max + 1) {
        teleportTo(current - width);
      }
    };

    const centerSlide = (index, behavior = 'smooth') => {
      const clamped = Math.max(0, Math.min(index, allSlides.length - 1));
      viewport.scrollTo({ left: centerLeftOf(allSlides[clamped]), behavior });
    };

    const stopAutoplay = () => {
      if (autoplayTimer !== null) {
        window.clearTimeout(autoplayTimer);
        autoplayTimer = null;
      }
    };

    const startAutoplay = () => {
      stopAutoplay();

      if (
        !autoplayEnabled
        || reducedMotion.matches
        || document.hidden
        || isDragging
        || isPointerInside
        || viewport.contains(document.activeElement)
      ) return;

      autoplayTimer = window.setTimeout(() => {
        normalize();
        centerSlide(closestSlideIndex() + 1);
        startAutoplay();
      }, autoplayInterval);
    };

    /* Normalize once scrolling has settled (covers autoplay, drag and snap). */
    const scheduleNormalize = () => {
      if (settleTimer !== null) window.clearTimeout(settleTimer);
      settleTimer = window.setTimeout(() => {
        settleTimer = null;
        normalize();
      }, 120);
    };

    if ('onscrollend' in window) {
      viewport.addEventListener('scrollend', normalize);
    } else {
      viewport.addEventListener('scroll', scheduleNormalize, { passive: true });
    }

    requestAnimationFrame(() => {
      centerSlide(initialIndex, 'auto');
      startAutoplay();
    });

    viewport.addEventListener('pointerdown', (event) => {
      if (event.button !== 0) return;

      stopAutoplay();
      normalize();
      isDragging = true;
      startX = event.clientX;
      startScrollLeft = viewport.scrollLeft;
      viewport.classList.add('is-dragging');
      viewport.setPointerCapture(event.pointerId);
    });

    viewport.addEventListener('pointermove', (event) => {
      if (!isDragging) return;

      viewport.scrollLeft = startScrollLeft - (event.clientX - startX);
    });

    const stopDragging = (event) => {
      if (!isDragging) return;

      isDragging = false;
      viewport.classList.remove('is-dragging');

      if (viewport.hasPointerCapture(event.pointerId)) {
        viewport.releasePointerCapture(event.pointerId);
      }

      normalize();
      centerSlide(closestSlideIndex());
      startAutoplay();
    };

    viewport.addEventListener('pointerup', stopDragging);
    viewport.addEventListener('pointercancel', stopDragging);

    viewport.addEventListener('keydown', (event) => {
      if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;

      event.preventDefault();
      stopAutoplay();
      normalize();

      centerSlide(closestSlideIndex() + (event.key === 'ArrowRight' ? 1 : -1));
    });

    viewport.addEventListener('mouseenter', () => {
      isPointerInside = true;
      stopAutoplay();
    });

    viewport.addEventListener('mouseleave', () => {
      isPointerInside = false;
      startAutoplay();
    });

    viewport.addEventListener('focusin', stopAutoplay);
    viewport.addEventListener('focusout', () => {
      window.requestAnimationFrame(startAutoplay);
    });

    let resizeTimer = null;
    window.addEventListener('resize', () => {
      if (resizeTimer !== null) window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        resizeTimer = null;
        normalize();
        centerSlide(closestSlideIndex(), 'auto');
      }, 150);
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoplay();
      } else {
        startAutoplay();
      }
    });

    reducedMotion.addEventListener?.('change', startAutoplay);
    section.addEventListener('shopify:section:unload', stopAutoplay);
  })();
</script>

{% schema %}
{
  "name": "What People Are Saying",
  "tag": "section",
  "class": "section section-home-revamp-testimonials",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_top",
      "label": "Top line",
      "default": "What people"
    },
    {
      "type": "text",
      "id": "heading_bottom",
      "label": "Bottom line",
      "default": "are saying"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "text",
      "id": "slider_label",
      "label": "Accessible slider label",
      "default": "Customer testimonials"
    },
    {
      "type": "range",
      "id": "initial_slide",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Initial centered slide",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Automatically change slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Time between slides",
      "default": 3
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 24,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "label": "Desktop card width",
      "default": 31
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "vw",
      "label": "Desktop card gap",
      "default": 7
    },
    {
      "type": "header",
      "content": "Stars image"
    },
    {
      "type": "image_picker",
      "id": "stars_image",
      "label": "Shared stars image",
      "info": "Used on every testimonial card. Leave blank to use the text stars and each block's rating."
    },
    {
      "type": "range",
      "id": "stars_image_width",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "vw",
      "label": "Desktop image width",
      "default": 11
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#D1EDE7"
    },
    {
      "type": "color",
      "id": "heading_background",
      "label": "Heading background",
      "default": "#205085"
    },
    {
      "type": "color",
      "id": "heading_top_color",
      "label": "Top heading text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_bottom_color",
      "label": "Bottom heading text",
      "default": "#A9D7EE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card text",
      "default": "#182A4A"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border",
      "default": "#205085"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Stars",
      "default": "#FFB400"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "In just 24 hours, I saw a major improvement. Now I feel confident in pursuing my dreams. Your products are truly a lifesaver."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Nikia"
        },
        {
          "type": "text",
          "id": "author_label",
          "label": "Author label",
          "default": "Verified User"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Card background",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What People Are Saying",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "In just 24 hours, I saw a major improvement. Now I feel confident in pursuing my dreams. Your products are truly a lifesaver.",
            "author": "Nikia",
            "author_label": "Verified User"
          }
        },
        {
          "type": "testimonial",
