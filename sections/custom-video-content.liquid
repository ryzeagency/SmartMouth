{%- style -%}
  .section-{{ section.id }}-wrapper {
    background-color: {{ section.settings.bg_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .split-video-grid-{{ section.id }} {
    align-items: center; /* Vertically centers the text with the video */
  }

  .split-text-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
  }

  /* Desktop Layout Ordering & Padding */
  @media screen and (min-width: 750px) {
    /* If video is on the LEFT */
    .split-layout-left-{{ section.id }} .split-video-column {
      order: 1;
    }
    .split-layout-left-{{ section.id }} .split-text-column {
      order: 2;
    }
    .split-layout-left-{{ section.id }} .split-text-content-{{ section.id }} {
      padding-left: 4rem;
    }

    /* If video is on the RIGHT */
    .split-layout-right-{{ section.id }} .split-video-column {
      order: 2;
    }
    .split-layout-right-{{ section.id }} .split-text-column {
      order: 1;
    }
    .split-layout-right-{{ section.id }} .split-text-content-{{ section.id }} {
      padding-right: 4rem;
    }
  }

  .split-text-content-{{ section.id }} .h2 {
    margin-top: 0;
    margin-bottom: 2rem;
    font-weight: bold;
    font-size: clamp(2.4rem, 3vw, 3.2rem);
    color: {{ section.settings.heading_color }};
  }

  .split-text-content-{{ section.id }} .rte {
    color: {{ section.settings.text_color }};
    line-height: 1.6;
    font-size: 1.5rem;
  }

  .split-text-content-{{ section.id }} .rte p {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  /* Button Styling */
  .split-video-btn-{{ section.id }} {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border: 0;
    padding: 0 3rem;
    cursor: pointer;
    font: inherit;
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
    min-height: 4.6rem;
    border-radius: 4rem; /* Pill shape */
    letter-spacing: 0.1rem;
    text-transform: uppercase;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    margin-top: 1rem;
    width: fit-content;
  }

  .split-video-btn-{{ section.id }}:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }

  /* Responsive 16:9 Video Wrapper */
  .video-wrapper-{{ section.id }} {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    border-radius: var(--media-radius);
    background-color: rgba(var(--color-foreground), 0.04);
    width: 100%;
  }

  .video-wrapper-{{ section.id }} iframe,
  .video-wrapper-{{ section.id }} .placeholder-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-wrapper-{{ section.id }} .placeholder-svg {
    fill: rgba(var(--color-foreground), 0.2);
    padding: 4rem;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-wrapper">
  <div class="split-section section-{{ section.id }}-padding page-width">

    <div class="grid grid--1-col grid--2-col-tablet split-video-grid-{{ section.id }} split-layout-{{ section.settings.layout }}-{{ section.id }}">
      
      <div class="grid__item split-video-column">
        <div class="video-wrapper-{{ section.id }}">
          {%- if section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?enablejsapi=1&rel=0" class="js-youtube" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}"></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}" class="js-vimeo" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}"></iframe>
            {%- endif -%}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      <div class="grid__item split-text-column">
        <div class="split-text-content-{{ section.id }}">
          {%- if section.settings.heading != blank -%}
            <h2 class="h2">{{ section.settings.heading }}</h2>
          {%- endif -%}
          
          {%- if section.settings.text != blank -%}
            <div class="rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link | default: '#' }}" class="split-video-btn-{{ section.id }}">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split Video & Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Background"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Video placement on desktop",
      "options": [
        {
          "value": "left",
          "label": "Video on left"
        },
        {
          "value": "right",
          "label": "Video on right"
        }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#eefaf2"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "YouTube or Vimeo link"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Split Video & Text"
    }
  ]
}
{% endschema %}