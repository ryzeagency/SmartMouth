{{ 'section-science.css' | asset_url | stylesheet_tag }}

<section class="science-section" style="background-color: {{ section.settings.background_color }};">
  <div class="science-section__container page-width">
    <div class="science-section__text">
      {% if section.settings.heading != blank %}
        <h2 class="science-section__heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% for block in section.blocks %}
        <div class="science-section__block" {{ block.shopify_attributes }}>
          {% if block.settings.block_heading != blank %}
            <h3 class="science-section__block-heading" style="color: {{ section.settings.heading_color }};">
              {{ block.settings.block_heading }}
            </h3>
          {% endif %}
          {% if block.settings.block_text != blank %}
            <div class="science-section__block-text" style="color: {{ section.settings.text_color }};">
              {{ block.settings.block_text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.image != blank %}
      <div class="science-section__image-wrapper">
        <img
          src="{{ section.settings.image | image_url: width: 500 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
          width="500"
          height="350"
          class="science-section__image"
        >
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Science Section",
  "tag": "section",
  "class": "section-science",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SmartMouth™ Science"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#e0f5e0"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a8c3a"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section image"
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "block_heading",
          "label": "Block heading",
          "default": "Sulfur Gas: The real cause of bad breath"
        },
        {
          "type": "richtext",
          "id": "block_text",
          "label": "Block text",
          "default": "<p>When the bacteria in our mouth eat protein particles found in saliva, they release stinky sulfur gas AKA bad breath.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Section",
      "blocks": [
        {
          "type": "text_block",
          "settings": {
            "block_heading": "Sulfur Gas: The real cause of bad breath",
            "block_text": "<p>When the bacteria in our mouth eat protein particles found in saliva, they release stinky sulfur gas AKA bad breath.</p>"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "block_heading": "Our Smart-Zinc Technology: The real solution to bad breath",
            "block_text": "<p>When our Sulfur Eliminating Solution and Zinc Activating Solution combine, they block germs from consuming protein — preventing bad breath for 24 hours with just two rinses a day.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
