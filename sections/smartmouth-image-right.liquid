<section class="custom-image-text" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="custom-image-text__container {% if section.settings.layout == 'left' %}custom-image-text__container--image-left{% endif %}">
    
    <div class="custom-image-text__content">
      {% if section.settings.main_heading != blank %}
        <h2 class="custom-image-text__main-heading" style="color: {{ section.settings.text_color }};">
          {{ section.settings.main_heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading_1 != blank or section.settings.text_1 != blank %}
        <div class="custom-image-text__block">
          {% if section.settings.subheading_1 != blank %}
            <h3 class="custom-image-text__subheading" style="color: {{ section.settings.text_color }};">
              {{ section.settings.subheading_1 }}
            </h3>
          {% endif %}
          {% if section.settings.text_1 != blank %}
            <p class="custom-image-text__text" style="color: {{ section.settings.text_color }};">
              {{ section.settings.text_1 }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.subheading_2 != blank or section.settings.text_2 != blank %}
        <div class="custom-image-text__block">
          {% if section.settings.subheading_2 != blank %}
            <h3 class="custom-image-text__subheading" style="color: {{ section.settings.text_color }};">
              {{ section.settings.subheading_2 }}
            </h3>
          {% endif %}
          {% if section.settings.text_2 != blank %}
            <p class="custom-image-text__text" style="color: {{ section.settings.text_color }};">
              {{ section.settings.text_2 }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="custom-image-text__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | default: section.settings.main_heading | escape }}"
          loading="lazy"
          width="800"
          height="{{ 800 | divided_by: section.settings.image.aspect_ratio | round }}"
          class="custom-image-text__image"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Custom Image with Text",
  "tag": "section",
  "class": "section-custom-image-text",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0073c8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop Image Placement",
      "options": [
        {
          "value": "left",
          "label": "Image on left"
        },
        {
          "value": "right",
          "label": "Image on right"
        }
      ],
      "default": "right"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "SmartMouth™ Science"
    },
    {
      "type": "text",
      "id": "subheading_1",
      "label": "Block 1 Heading",
      "default": "Sulfur Gas: The real cause of bad breath"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Block 1 Text",
      "default": "When the bacteria in our mouth eat protein particles found in saliva, they release stinky sulfur gas AKA bad breath"
    },
    {
      "type": "text",
      "id": "subheading_2",
      "label": "Block 2 Heading",
      "default": "Our Smart-Zinc Technology: The real solution to bad breath"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Block 2 Text",
      "default": "When our Sulfur Eliminating Solution and Zinc Activating Solution combine, they block germs from consuming protein — preventing bad breath for 24 hours with just two rinses a day"
    }
  ],
  "presets": [
    {
      "name": "Custom Image with Text"
    }
  ]
}
{% endschema %}