{% liquid
  assign science_link = section.settings.button_link | default: '/pages/the-science'
%}

<section
  class="hr-science"
  data-science-section="{{ section.id }}"
  aria-labelledby="ScienceHeading-{{ section.id }}"
>
  <div class="hr-science__container">
    <div class="hr-science__content">
      {% if section.settings.eyebrow != blank %}
        <p class="hr-science__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading_prefix != blank or section.settings.heading_accent != blank or section.settings.heading_suffix != blank %}
        <h2 class="hr-science__heading" id="ScienceHeading-{{ section.id }}">
          {{ section.settings.heading_prefix | escape }} <span>{{ section.settings.heading_accent | escape }}</span> {{ section.settings.heading_suffix | escape }}
        </h2>
      {% endif %}

      {% if section.settings.intro != blank %}
        <div class="hr-science__intro rte">{{ section.settings.intro }}</div>
      {% endif %}

      <ul class="hr-science__bullets list-unstyled" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'bullet' %}
            <li class="hr-science__bullet" {{ block.shopify_attributes }}>
              <span class="hr-science__bullet-icon" aria-hidden="true">
                {% if block.settings.icon != blank %}
                  {{
                    block.settings.icon
                    | image_url: width: 120
                    | image_tag:
                      widths: '40, 60, 80, 100, 120',
                      sizes: '(min-width: 750px) 1.55vw, 7vw',
                      loading: 'lazy',
                      alt: ''
                  }}
                {% else %}
                  <span class="hr-science__arrow">→</span>
                {% endif %}
              </span>
              <span>{{ block.settings.text | escape }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% if section.settings.button_label != blank %}
        <a class="button hr-science__button" href="{{ science_link }}">
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}
    </div>

    <div class="hr-science__visual">
      {% for block in section.blocks %}
        {% if block.type == 'solution' %}
          {% liquid
            assign delay_seconds = block.settings.animation_delay | times: 0.1
          %}
          <article
            class="hr-science__solution hr-science__solution--{{ block.settings.position }}"
            style="
              --solution-width: {{ block.settings.card_width }}vw;
              --solution-top: {{ block.settings.top_offset }}vw;
              --solution-offset: {{ block.settings.side_offset }}vw;
              --solution-bg: {{ block.settings.background_color }};
              --solution-text: {{ block.settings.text_color }};
              --solution-label-bg: {{ block.settings.label_background }};
              --solution-label-text: {{ block.settings.label_color }};
              --solution-delay: {{ delay_seconds }}s;
            "
            {{ block.shopify_attributes }}
          >
            {% if block.settings.label != blank %}
              <h3 class="hr-science__solution-label">{{ block.settings.label | escape }}</h3>
            {% endif %}

            {% if block.settings.body != blank %}
              <p class="hr-science__solution-copy">
                {{ block.settings.body | escape | newline_to_br }}
              </p>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}

      <div class="hr-science__product">
        {% if section.settings.product_image != blank %}
          {{
            section.settings.product_image
            | image_url: width: 1600
            | image_tag:
              widths: '500, 750, 1000, 1200, 1400, 1600',
              sizes: '(min-width: 750px) 25.15vw, 60vw',
              loading: 'lazy',
              alt: section.settings.image_alt
          }}
        {% else %}
          <img
            src="{{ 'howsmart-img.webp' | asset_url }}"
            alt="{{ section.settings.image_alt | escape }}"
            width="515"
            height="598"
            loading="lazy"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --hr-science-bg: {{ section.settings.background_color }};
    --hr-science-text: {{ section.settings.text_color }};
    --hr-science-blue: {{ section.settings.heading_background }};
    --hr-science-heading-text: {{ section.settings.heading_color }};
    --hr-science-accent: {{ section.settings.accent_color }};
    --hr-science-arrow: {{ section.settings.arrow_color }};
    --hr-science-button: {{ section.settings.button_color }};
    --hr-science-button-text: {{ section.settings.button_text_color }};
  }

  #shopify-section-{{ section.id }} .hr-science {
    overflow: hidden;
    padding: 4.65vw 0 5vw;
    color: var(--hr-science-text);
    background: var(--hr-science-bg);
  }

  #shopify-section-{{ section.id }} .hr-science__container {
    position: relative;
    width: 85vw;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .hr-science__content {
    position: relative;
    z-index: 2;
    width: 34vw;
    margin-left: 1vw;
  }

  #shopify-section-{{ section.id }} .hr-science__eyebrow {
    margin: 0 0 .55vw 1vw;
    color: var(--hr-science-blue);
    font-size: 1.5vw;
    font-weight: 500;
    letter-spacing: .02vw;
    line-height: 1.2;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .hr-science__heading {
    display: table;
    margin: 0 0 1.25vw;
    padding: .55vw .9vw .65vw;
    color: var(--hr-science-heading-text);
    background: var(--hr-science-blue);
    font-family: var(--font-heading-family);
    font-size: 2.4vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .hr-science__heading span {
    color: var(--hr-science-accent);
  }

  #shopify-section-{{ section.id }} .hr-science__intro {
    max-width: 33vw;
    margin: 0 0 1.25vw 1.3vw;
    color: inherit;
    font-size: 1.12vw;
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .hr-science__intro p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hr-science__bullets {
    display: grid;
    gap: 1.75vw;
    margin: 0 0 2.65vw 1.45vw;
  }

  #shopify-section-{{ section.id }} .hr-science__bullet {
    display: grid;
    grid-template-columns: 1.55vw minmax(0, 1fr);
    align-items: start;
    gap: .65vw;
    font-size: 1vw;
    font-weight: 500;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .hr-science__bullet-icon {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 1.55vw;
  }

  #shopify-section-{{ section.id }} .hr-science__bullet-icon img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .hr-science__arrow {
    color: var(--hr-science-arrow);
    font-size: 1.8vw;
    font-weight: 400;
    line-height: .72;
  }

  #shopify-section-{{ section.id }} .hr-science__button.button {
    min-width: 18vw;
    margin-left: 1.3vw;
    padding: .9vw 1.8vw;
    color: var(--hr-science-button-text);
    background: var(--hr-science-button);
    border: 0;
    border-radius: 2vw;
    font-size: 1.18vw;
    font-weight: 800;
    line-height: 1;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .hr-science__button.button::before,
  #shopify-section-{{ section.id }} .hr-science__button.button::after {
    content: none;
  }

  #shopify-section-{{ section.id }} .hr-science__visual {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .hr-science__product {
    position: absolute;
    top: -4.65vw;
    right: 9.5vw;
    z-index: 3;
    width: 25.15vw;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .hr-science__product img {
    display: block;
    width: 100%;
    height: auto;
  }

  #shopify-section-{{ section.id }} .hr-science__solution {
    position: absolute;
    top: var(--solution-top);
    z-index: 2;
    width: var(--solution-width);
    padding: 1.85vw 1.55vw 1.55vw;
    color: var(--solution-text);
    background: var(--solution-bg);
    box-sizing: border-box;
    opacity: 0;
    transition:
      opacity 1.15s ease var(--solution-delay),
      transform 1.35s cubic-bezier(.2, .75, .3, 1) var(--solution-delay);
  }

  #shopify-section-{{ section.id }} .hr-science__solution--left {
    left: var(--solution-offset);
    transform: translateX(-5vw);
  }

  #shopify-section-{{ section.id }} .hr-science__solution--right {
    right: var(--solution-offset);
    transform: translateX(5vw);
    padding-left: 4vw;
  }

  #shopify-section-{{ section.id }} .hr-science.is-visible .hr-science__solution {
    opacity: 1;
    transform: translateX(0);
  }

  #shopify-section-{{ section.id }} .hr-science__solution-label {
    display: table;
    margin: 0 0 .75vw;
    padding: .35vw 1.05vw .42vw;
    color: var(--solution-label-text);
    background: var(--solution-label-bg);
    border-radius: 2vw;
    font-family: var(--font-heading-family);
    font-size: 1.15vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .hr-science__solution-copy {
    margin: 0;
    font-size: 1.08vw;
    font-weight: 500;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hr-science {
      padding: 0 0 12vw;
    }

    #shopify-section-{{ section.id }} .hr-science__container {
      display: flex;
      flex-wrap: wrap;
      flex-direction: column-reverse;
  }

    #shopify-section-{{ section.id }} .hr-science__content {
      width: 85vw;
      margin: 0;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .hr-science__eyebrow {
      margin: 0 0 3vw;
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .hr-science__heading {
      margin-bottom: 6vw;
      padding: 2vw 3vw 2.4vw;
      font-size: 7.2vw;
      white-space: normal;
    }

    #shopify-section-{{ section.id }} .hr-science__intro {
      max-width: none;
      margin: 0 0 7vw;
      font-size: 3.5vw;
    }

    #shopify-section-{{ section.id }} .hr-science__bullets {
      gap: 4vw;
      margin: 0 0 9vw;
    }

    #shopify-section-{{ section.id }} .hr-science__bullet {
      grid-template-columns: 7vw minmax(0, 1fr);
      gap: 2vw;
      font-size: 3.5vw;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .hr-science__bullet-icon {
      width: 7vw;
    }

    #shopify-section-{{ section.id }} .hr-science__arrow {
      font-size: 7vw;
    }

    #shopify-section-{{ section.id }} .hr-science__button.button {
      min-width: 66vw;
      margin: 0;
      padding: 3.4vw 6vw;
      border-radius: 8vw;
      font-size: 3.5vw;
    }

    #shopify-section-{{ section.id }} .hr-science__visual {
      position: relative;
      inset: auto;
      width: 85vw;
      aspect-ratio: .8;
      margin-top: 0;
    }

    #shopify-section-{{ section.id }} .hr-science__product {
      top: 0;
      right: 12vw;
      width: 60vw;
    }

    #shopify-section-{{ section.id }} .hr-science__solution {
      width: 43vw;
      padding: 3vw;
      height: 30vw;
    }

    #shopify-section-{{ section.id }} .hr-science__solution--left {
      top: 70vw;
      left: 0;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .hr-science__solution--right {
      top: 70vw;
      right: 0;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .hr-science__solution-label {
      margin-bottom: 3vw;
      padding: 1.5vw 4vw 1.8vw;
      border-radius: 7vw;
      font-size: 3vw;
      display: inline-block;
    }

    #shopify-section-{{ section.id }} .hr-science__solution-copy {
      font-size: 2.5vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .hr-science__solution {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('[data-science-section="{{ section.id }}"]');

    if (!section || section.dataset.animationReady === 'true') return;

    section.dataset.animationReady = 'true';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      section.classList.add('is-visible');
      return;
    }

    if (!('IntersectionObserver' in window)) {
      section.classList.add('is-visible');
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        section.classList.add('is-visible');
        observer.disconnect();
      });
    }, { threshold: 0.25 });

    observer.observe(section);
  })();
</script>

