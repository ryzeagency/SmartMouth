<section class="how-to-indicator" aria-labelledby="HowToIndicatorHeading-{{ section.id }}">
  <div class="how-to-indicator__container">
    <div class="how-to-indicator__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="how-to-indicator__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="HowToIndicatorHeading-{{ section.id }}" class="how-to-indicator__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="how-to-indicator__body rte">{{ section.settings.body }}</div>
      {% endif %}
    </div>

    <div class="how-to-indicator__visual{% if section.settings.indicator_image != blank %} how-to-indicator__visual--has-image{% endif %}">
      {% if section.settings.indicator_image != blank %}
        <div class="how-to-indicator__art">
          {{
            section.settings.indicator_image
            | image_url: width: 2000
            | image_tag:
              widths: '600, 900, 1200, 1600, 2000',
              sizes: '(min-width: 750px) 41vw, 85vw',
              loading: 'lazy',
              alt: section.settings.image_alt
          }}
        </div>
      {% endif %}

      <div class="how-to-indicator__cards">
        {% for block in section.blocks %}
          <article
            class="how-to-indicator__card"
            style="--indicator-card-background: {{ block.settings.background_color }}; --indicator-card-text: {{ block.settings.text_color }};"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              <div class="how-to-indicator__card-image">
                {{ 
                  block.settings.image 
                  | image_url: width: 800 
                  | image_tag: 
                    widths: '400, 600, 800',
                    sizes: '(min-width: 750px) 20vw, 40vw',
                    loading: 'lazy'
                }}
              </div>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h3 class="how-to-indicator__card-heading">{{ block.settings.heading | escape }}</h3>
            {% endif %}

            {% if block.settings.body != blank %}
              <div class="how-to-indicator__card-body rte">{{ block.settings.body }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --how-to-body-size: 1vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-block: {{ section.settings.padding_top }}vw {{ section.settings.padding_bottom }}vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) {{ section.settings.visual_width }}vw;
    gap: 6vw;
    align-items: center;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__copy {
    max-width: 37vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__eyebrow {
    margin: 0 0 1.25vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.45vw;
    font-style: var(--font-body-style);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.55vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__body,
  #shopify-section-{{ section.id }} .how-to-indicator__card-body {
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--how-to-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__body {
    margin-top: 2vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__body > *,
  #shopify-section-{{ section.id }} .how-to-indicator__card-body > * {
    margin-block: 0;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__visual {
    position: relative;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__art {
    position: relative;
    z-index: 2;
    width: {{ section.settings.image_width }}vw;
    margin: 0 auto -9.5vw;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__art img {
    display: block;
    width: 100%;
    height: auto;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__card {
    box-sizing: border-box;
    padding: 2.4vw 2.6vw 2vw;
    border-radius: 0.55vw;
    background: var(--indicator-card-background);
    color: var(--indicator-card-text);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__card-image {
    margin-bottom: 1.5vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__card-image img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__visual--has-image .how-to-indicator__card {
    padding-top: 10.7vw;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__card-heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.05vw;
    font-style: var(--font-body-style);
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .how-to-indicator__card-body {
    margin-top: 1.15vw;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --how-to-body-size: 4vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator {
      padding-block: {{ section.settings.mobile_padding_top }}vw {{ section.settings.mobile_padding_bottom }}vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__container {
      grid-template-columns: 1fr;
      gap: 10vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__copy {
      max-width: none;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__eyebrow {
      margin-bottom: 3vw;
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__heading {
      font-size: 8vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__body {
      margin-top: 5vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__art {
      width: 85vw;
      margin-bottom: -20vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__cards {
      gap: 3vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__card {
      padding: 6vw 3vw;
      border-radius: 2vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__card-image {
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__visual--has-image .how-to-indicator__card {
      padding-top: 23vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__card-heading {
      font-size: 4.4vw;
    }

    #shopify-section-{{ section.id }} .how-to-indicator__card-body {
      margin-top: 3vw;
    }
  }
</style>

{% schema %}
{
  "name": "How To Color Indicator",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE COLOR INDICATOR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You activate the zinc ions."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>When the two solutions come together, a chemical reaction occurs that instantly releases billions of zinc ions. Here’s what the color tells you.</p>"
    },
    {
      "type": "header",
      "content": "Cup and icons image"
    },
    {
      "type": "image_picker",
      "id": "indicator_image",
      "label": "Combined image (Optional over cards)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Green ready cup and blue pour-again cup indicators"
    },
    {
      "type": "range",
      "id": "visual_width",
      "min": 35,
      "max": 50,
      "step": 1,
      "unit": "vw",
      "label": "Desktop visual width",
      "default": 41
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 50,
      "step": 1,
      "unit": "vw",
      "label": "Desktop image width",
      "default": 41
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FBF4E3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#06264A"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop top spacing",
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "vw",
      "label": "Desktop bottom spacing",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "vw",
      "label": "Mobile top spacing",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "vw",
      "label": "Mobile bottom spacing",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "indicator",
      "name": "Indicator card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Green = Ready"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>The solution is freshly activated and the zinc ions are ready to bind to germs. This is when SmartMouth™ is at full potency — rinse immediately.</p>"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Card background",
          "default": "#DDF9F2"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Card text",
          "default": "#06264A"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To Color Indicator",
      "category": "How To Revamp",
      "blocks": [
        {
          "type": "indicator"
        },
        {
          "type": "indicator",
          "settings": {
            "heading": "Blue = pour again",
            "body": "<p>If you wait 5 minutes after pouring, the solution turns blue — meaning the zinc ions are no longer as effective at preventing bad breath. Pour a fresh cup.</p>",
            "background_color": "#CDE5F8",
            "text_color": "#285B91"
          }
        }
      ]
    }
  ]
}
{% endschema %}