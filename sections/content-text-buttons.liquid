      "label": "Button 2 Label"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "color",
      "id": "btn2_bg_color",
      "label": "Button 2 Background",
      "default": "#008037"
    },
    {
      "type": "color",
      "id": "btn2_text_color",
      "label": "Button 2 Text",
      "default": "#ffffff"
