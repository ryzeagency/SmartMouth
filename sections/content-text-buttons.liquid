      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Content with Dual Buttons",
      "settings": {
        "heading": "Sign up to receive patient handouts for our SmartMouth Clinical DDS Activated Oral Rinse for your dental practice.",
        "text": "<p>Whether your patients need to eliminate bad breath, relieve dry mouth, or help prevent gingivitis and gum disease before it becomes a clinical issue, SmartMouth offers multiple formulations which are scientifically proven to work.</p><p>Our extended line of oral health products, including Dry Mouth Mints and SmartMouth Premium Toothpaste, can supplement your patients' oral health and dental care with added benefits to help alleviate any issues.</p><p><strong>Sign up today to receive patient handouts, exclusive benefits, and access to future initiatives!</strong></p>",
