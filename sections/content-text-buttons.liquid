{%- style -%}
  .section-{{ section.id }}-wrapper {
    background-color: {{ section.settings.bg_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .text-buttons-container-{{ section.id }} {
    max-width: 900px; /* Constrains the width to match the line-breaks in your mockup */
    margin: 0 auto;
    text-align: center;
  }

  .text-buttons-container-{{ section.id }} h2 {
    color: {{ section.settings.text_color }};
    font-size: clamp(2.4rem, 3.5vw, 3.2rem);
    font-weight: bold;
    line-height: 1.3;
    margin-top: 0;
    margin-bottom: 2.5rem;
  }

  .text-buttons-container-{{ section.id }} .rte {
    color: {{ section.settings.text_color }};
    font-size: 1.5rem;
    line-height: 1.6;
    margin-bottom: 4rem;
    opacity: 0.85;
  }

  .text-buttons-container-{{ section.id }} .rte p {
    margin-bottom: 1.5rem;
  }
  
  .text-buttons-container-{{ section.id }} .rte p:last-child {
    margin-bottom: 0;
  }

  /* Flexbox for the side-by-side buttons */
  .text-buttons-group-{{ section.id }} {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap; /* Allows buttons to stack nicely on very small mobile screens */
  }

  .text-buttons-btn-{{ section.id }} {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border: 0;
    padding: 0 3rem;
    cursor: pointer;
    font: inherit;
    font-size: 1.2rem;
    font-weight: 700;
    text-decoration: none;
    min-height: 4.4rem;
    border-radius: 4rem; /* Pill shape */
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .text-buttons-btn-{{ section.id }}:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }

  /* Individual Button Colors */
  .btn-primary-{{ section.id }} {
    background-color: {{ section.settings.btn1_bg_color }};
    color: {{ section.settings.btn1_text_color }};
  }

  .btn-secondary-{{ section.id }} {
    background-color: {{ section.settings.btn2_bg_color }};
    color: {{ section.settings.btn2_text_color }};
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-wrapper">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="text-buttons-container-{{ section.id }}">
      
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      <div class="text-buttons-group-{{ section.id }}">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_link | default: '#' }}" class="text-buttons-btn-{{ section.id }} btn-primary-{{ section.id }}">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link | default: '#' }}" class="text-buttons-btn-{{ section.id }} btn-secondary-{{ section.id }}">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

