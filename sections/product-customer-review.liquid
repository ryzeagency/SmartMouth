{%- if product.metafields.custom.product_amazon_customer_reviews_section != blank -%}
  <div class="amazon-reviews-wrapper" id="AmazonReviews-{{ section.id }}">
    <div class="amazon-reviews-container">
      
      {%- if section.settings.heading != blank -%}
        <h2 class="amazon-reviews-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="amazon-reviews-content">
        {{ product.metafields.custom.product_amazon_customer_reviews_section }}
      </div>
      
    </div>
  </div>
{%- endif -%}

<style>
  #AmazonReviews-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    width: 100%;
  }

  .amazon-reviews-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
    text-align: {{ section.settings.text_alignment }};
  }

  .amazon-reviews-heading {
    margin-bottom: 24px;
    font-size: 30px;
  }

  .amazon-reviews-content {
    /* Ensures any embedded iframes or scripts fit correctly */
    width: 100%;
    overflow: hidden; 
  }

  /* Mobile responsiveness for padding */
  @media screen and (max-width: 768px) {
    #AmazonReviews-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Amazon Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Amazon Reviews",
      "category": "Product"
    }
  ]
}
{% endschema %}