{{ 'section-logo-list.css' | asset_url | stylesheet_tag }}

<section class="logo-list-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="logo-list__container">
    
    {% if section.settings.heading != blank %}
      <h2 class="logo-list__heading" style="--heading-color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="logo-list__grid">
      {% for block in section.blocks %}
        <div class="logo-list__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="logo-list__link" target="_blank" rel="noopener noreferrer">
          {% endif %}

          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.image.alt | default: 'Featured in publisher logo' | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="logo-list__image"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg logo-list__image' }}
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Logo List",
  "tag": "section",
  "class": "section-logo-list",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Featured in"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)",
          "info": "Links the logo to the featured article."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo List",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}