<section class="where-to-buy-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="where-to-buy__container">
    
    {% if section.settings.heading != blank %}
      <h2 class="where-to-buy__heading" style="--heading-color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="where-to-buy__text" style="--text-color: {{ section.settings.text_color }};">
        {{ section.settings.text }}
      </p>
    {% endif %}

    <div class="where-to-buy__buttons">
      {% if section.settings.button_label_1 != blank %}
        <a 
          href="{{ section.settings.button_url_1 }}" 
          class="where-to-buy__btn"
          style="background-color: {{ section.settings.button_bg_1 }}; color: {{ section.settings.button_text_1 }};"
        >
          {{ section.settings.button_label_1 }}
        </a>
      {% endif %}

      {% if section.settings.button_label_2 != blank %}
        <a 
          href="{{ section.settings.button_url_2 }}" 
          class="where-to-buy__btn"
          style="background-color: {{ section.settings.button_bg_2 }}; color: {{ section.settings.button_text_2 }};"
        >
          {% if section.settings.show_amazon_icon %}
            <img src="https://cdn.shopify.com/s/files/1/0888/4578/files/social.png?v=1776461517">
          {% endif %}
          {{ section.settings.button_label_2 }}
        </a>
      {% endif %}
    </div>

  </div>

  <div class="where-to-buy__image-wrapper">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | default: 'SmartMouth product lineup' | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        class="where-to-buy__image"
      >
    {% else %}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

</section>

{% schema %}
{
  "name": "Where to Buy",
  "tag": "section",
  "class": "section-where-to-buy",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SmartMouth is available on Amazon and in stores Nationwide"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#222222"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "Purchase SmartMouth™ mouthwash and oral care products from regional and national retailers near you. So you can be sure – no matter where you go – bad breath doesn’t follow."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button Label",
      "default": "WHERE TO BUY"
    },
    {
      "type": "url",
      "id": "button_url_1",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_1",
      "label": "Button Background",
      "default": "#0072ce"
    },
    {
      "type": "color",
      "id": "button_text_1",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 2 (Amazon)"
    },
    {
      "type": "checkbox",
      "id": "show_amazon_icon",
      "label": "Show Amazon Icon",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button Label",
      "default": "BUY ON AMAZON"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_2",
      "label": "Button Background",
      "default": "#008035"
    },
    {
      "type": "color",
      "id": "button_text_2",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Product Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Lineup Image"
    }
  ],
  "presets": [
    {
      "name": "Where to Buy"
    }
  ]
}
{% endschema %}