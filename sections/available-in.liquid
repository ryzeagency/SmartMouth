<section class="where-to-buy-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="where-to-buy__container">
    
    {% if section.settings.heading != blank %}
      <h2 class="where-to-buy__heading" style="--heading-color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="where-to-buy__text" style="--text-color: {{ section.settings.text_color }};">
        {{ section.settings.text }}
      </p>
    {% endif %}

    <div class="where-to-buy__buttons">
      {% if section.settings.button_label_1 != blank %}
        <a 
          href="{{ section.settings.button_url_1 }}" 
          class="where-to-buy__btn"
          style="background-color: {{ section.settings.button_bg_1 }}; color: {{ section.settings.button_text_1 }};"
        >
          {{ section.settings.button_label_1 }}
        </a>
      {% endif %}

      {% if section.settings.button_label_2 != blank %}
        <a 
          href="{{ section.settings.button_url_2 }}" 
          class="where-to-buy__btn"
          style="background-color: {{ section.settings.button_bg_2 }}; color: {{ section.settings.button_text_2 }};"
        >
          {% if section.settings.show_amazon_icon %}
            <svg class="where-to-buy__btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
              <path d="M257.2 162.7c-36.7-1.3-83.4 18.1-106.3 51.4-12.4 18.1-19.1 39.7-19.1 63.3 0 41.5 29.5 73.1 72.4 73.1 39.5 0 71.9-25.1 89.2-61.7v-16.1c-22.1 14.3-47.4 22.1-73.8 22.1-43.5 0-79.9-24.6-79.9-68.5 0-41.5 31.6-73.6 82.2-73.6 23.4 0 49.3 6.5 68.3 18.1V162.7zm-22.4 148.6c-17.1 24.6-43.7 40.2-74.9 40.2-22.1 0-44.2-7.8-60.8-22.1-15.6-13-24.4-32.4-24.4-53.2 0-38.9 31.1-66.2 73.8-66.2 26 0 53.2 9.1 71.4 22v79.3zm204.9-183.9c-48.6-8.5-98.4 6.6-132.2 41.8-19.5 20.3-31.2 46.8-31.2 75.3v138c0 10.4-8.6 18.9-19.1 18.9h-44.1v-44.1c13.6 0 24.6-11 24.6-24.6V187.9c0-37.5 15.5-73.2 43.1-99.7 28-26.8 87-46.2 147-35.7 53.2 9.3 99.6 42.1 125.6 88.5 12.3 22 19.4 46.8 20.5 72.3h-42.1c-1.1-23.3-9.7-45.5-24.5-64.4-23.3-29.6-57.8-49.8-94.6-54.8zM448 405.3c-58.4 34.6-128.5 54.1-201.2 54.1-71.1 0-139.7-18.3-197.6-51.4-7.8-4.5-16.9-4.5-24.6 0l-14.3 8.3c-7.8 4.5-7.8 11.7 0 16.2 62.3 35.7 134.3 56.4 209.6 56.4 76.6 0 150.5-21.4 214.8-59 7.8-4.5 7.8-11.7 0-16.2l-14.3-8.3c-7.7-4.5-16.8-4.5-24.5-.1z"/>
            </svg>
          {% endif %}
          {{ section.settings.button_label_2 }}
        </a>
      {% endif %}
    </div>

  </div>

  <div class="where-to-buy__image-wrapper">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | default: 'SmartMouth product lineup' | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        class="where-to-buy__image"
      >
    {% else %}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

</section>

{% schema %}
{
  "name": "Where to Buy",
  "tag": "section",
  "class": "section-where-to-buy",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SmartMouth is available on Amazon and in stores Nationwide"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#222222"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "Purchase SmartMouth™ mouthwash and oral care products from regional and national retailers near you. So you can be sure – no matter where you go – bad breath doesn’t follow."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button Label",
      "default": "WHERE TO BUY"
    },
    {
      "type": "url",
      "id": "button_url_1",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_1",
      "label": "Button Background",
      "default": "#0072ce"
    },
    {
      "type": "color",
      "id": "button_text_1",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 2 (Amazon)"
    },
    {
      "type": "checkbox",
      "id": "show_amazon_icon",
      "label": "Show Amazon Icon",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button Label",
      "default": "BUY ON AMAZON"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_2",
      "label": "Button Background",
      "default": "#008035"
    },
    {
      "type": "color",
      "id": "button_text_2",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Product Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Lineup Image"
    }
  ],
  "presets": [
    {
      "name": "Where to Buy"
    }
  ]
}
{% endschema %}