<section class="product-benefits" aria-labelledby="ProductBenefitsHeading-{{ section.id }}">
  <div class="product-benefits__inner">
    <div class="product-benefits__content">
      <h2 class="product-benefits__heading" id="ProductBenefitsHeading-{{ section.id }}">
        {{- section.settings.heading | default: 'What it does. Who it’s for.' | escape -}}
      </h2>

      {%- if section.settings.subheading != blank -%}
        <p class="product-benefits__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- liquid
        assign visible_cards = 0
        for block in section.blocks
          if block.settings.body != blank
            assign visible_cards = visible_cards | plus: 1
          endif
        endfor
      -%}

      {%- if visible_cards > 0 -%}
        <div class="product-benefits__grid" role="list">
          {%- for block in section.blocks -%}
            {%- if block.settings.body != blank -%}
              <article class="product-benefits__card" role="listitem" {{ block.shopify_attributes }}>
                <div class="product-benefits__body rte">{{ block.settings.body }}</div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --product-body-size: 1vw;
    --product-body-size-mobile: 3.5vw;
    --product-benefits-background: {{ section.settings.background_color }};
    --product-benefits-text: {{ section.settings.text_color }};
    --product-benefits-card: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .product-benefits {
    padding: 4vw 0 2.9vw;
    color: var(--product-benefits-text);
    background: var(--product-benefits-background);
  }

  #shopify-section-{{ section.id }} .product-benefits__inner {
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .product-benefits__content {
    width: 71.5vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .product-benefits__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.45vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.05;
  }

  #shopify-section-{{ section.id }} .product-benefits__subheading {
    margin: 0.9vw 0 0;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.15vw;
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .product-benefits__grid {
    display: grid;
    grid-template-columns: repeat({{ visible_cards | at_least: 1 }}, minmax(0, 1fr));
    align-items: stretch;
    gap: 2vw;
    margin-top: 2.45vw;
  }

  #shopify-section-{{ section.id }} .product-benefits__card {
    padding: 2.15vw 1.5vw 2vw;
    color: inherit;
    background: var(--product-benefits-card);
    border-radius: 0.8vw;
  }

  #shopify-section-{{ section.id }} .product-benefits__body {
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--product-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .product-benefits__body h3 {
    font-size: 1vw;
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .product-benefits__body p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .product-benefits {
      padding: 12vw 0 14vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__content {
      width: 85vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__heading {
      font-size: 6vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__subheading {
      margin-top: 3vw;
      font-size: 3.8vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__grid {
      grid-template-columns: 1fr;
      gap: 5vw;
      margin-top: 9vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__card {
      padding: 8vw 6vw;
      border-radius: 3vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__body {
      font-size: var(--product-body-size-mobile);
      line-height: 1.45;
    }
    #shopify-section-{{ section.id }} .product-benefits__body h3 {
      font-size: 4vw;
    }
  }
</style>

