<section class="product-benefits" aria-labelledby="ProductBenefitsHeading-{{ section.id }}">
  <div class="product-benefits__inner">
    <div class="product-benefits__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="product-benefits__heading" id="ProductBenefitsHeading-{{ section.id }}">
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="product-benefits__grid" role="list">
          {%- for block in section.blocks -%}
            <article class="product-benefits__card" role="listitem" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3>{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="product-benefits__body rte">{{ block.settings.body }}</div>
              {%- endif -%}
            </article>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --product-body-size: 1vw;
    --product-body-size-mobile: 4vw;
    --product-benefits-background: {{ section.settings.background_color }};
    --product-benefits-text: {{ section.settings.text_color }};
    --product-benefits-card: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .product-benefits {
    padding: 4vw 0 2.9vw;
    color: var(--product-benefits-text);
    background: var(--product-benefits-background);
  }

  #shopify-section-{{ section.id }} .product-benefits__inner {
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .product-benefits__content {
    width: 71.5vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .product-benefits__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.45vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.05;
  }

  #shopify-section-{{ section.id }} .product-benefits__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, minmax(0, 1fr));
    align-items: stretch;
    gap: 2vw;
    margin-top: 2.45vw;
  }

  #shopify-section-{{ section.id }} .product-benefits__card {
    padding: 2.15vw 1.5vw 2vw;
    color: inherit;
    background: var(--product-benefits-card);
    border-radius: 0.8vw;
  }

  #shopify-section-{{ section.id }} .product-benefits__card h3 {
    margin: 0 0 1vw;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 1.42vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.12;
  }

  #shopify-section-{{ section.id }} .product-benefits__body {
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--product-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .product-benefits__body p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .product-benefits {
      padding: 12vw 0 14vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__content {
      width: 85vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__heading {
      font-size: 6vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__grid {
      grid-template-columns: 1fr;
      gap: 5vw;
      margin-top: 9vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__card {
      padding: 8vw 6vw;
      border-radius: 3vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__card h3 {
      margin-bottom: 4vw;
      font-size: 4vw;
    }

    #shopify-section-{{ section.id }} .product-benefits__body {
      font-size: var(--product-body-size-mobile);
      line-height: 1.45;
    }
  }
</style>

{% schema %}
{
  "name": "Product What It Does",
  "tag": "section",
  "class": "section section-product-revamp-what-it-does",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What it does. Who it’s for."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FBF6E6"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#092847"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
