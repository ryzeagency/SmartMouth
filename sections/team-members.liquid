{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .team-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 5rem;
  }

  .team-header-{{ section.id }} h2 {
    font-weight: bold;
    margin: 0;
  }

  .team-list-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .team-member-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .team-member-{{ section.id }} {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 6rem;
    }
    
    .team-list-{{ section.id }} {
      gap: 6rem;
    }
  }

  .team-image-wrapper-{{ section.id }} {
    width: 100%;
    max-width: 260px;
    flex-shrink: 0;
  }

  .team-image-wrapper-{{ section.id }} img {
    width: 100%;
  }

  .team-image-{{ section.id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .team-content-{{ section.id }} {
    flex-grow: 1;
    padding-top: 1rem; /* Aligns text nicely with the top of the image */
  }

  .team-content-{{ section.id }} h3 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: clamp(1.6rem, 2vw, 1.8rem);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05rem;
  }

  .team-content-{{ section.id }} .rte {
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.5rem;
    line-height: 1.6;
  }

  .team-content-{{ section.id }} .rte p {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  /* Placeholder styling */
  .placeholder-svg-wrapper {
    width: 100%;
    height: 260px;
    background-color: rgba(var(--color-foreground), 0.04);
    border-radius: 50%; /* Makes the placeholder circular to mimic a headshot */
    overflow: hidden;
  }
  .placeholder-svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: rgba(var(--color-foreground), 0.2);
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  
  {%- if section.settings.title != blank -%}
    <div class="team-header-{{ section.id }}">
      <h2 class="h2">{{ section.settings.title }}</h2>
    </div>
  {%- endif -%}

  <div class="team-list-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="team-member-{{ section.id }}" {{ block.shopify_attributes }}>
        
        <div class="team-image-wrapper-{{ section.id }}">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: 
              class: 'team-image',
              loading: 'lazy',
              sizes: '(min-width: 750px) 260px, 100vw'
            }}
          {%- else -%}
            <div class="placeholder-svg-wrapper">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

        <div class="team-content-{{ section.id }}">
          {%- if block.settings.name != blank -%}
            <h3>{{ block.settings.name }}</h3>
          {%- endif -%}
          
          {%- if block.settings.bio != blank -%}
            <div class="rte">
              {{ block.settings.bio }}
            </div>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Team Members",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name & Title"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "Biography"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Members",
      "blocks": [
        { "type": "member" },
        { "type": "member" },
        { "type": "member" }
      ]
    }
  ]
}
{% endschema %}