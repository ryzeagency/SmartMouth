{{ 'section-custom-text.css' | asset_url | stylesheet_tag }}

<section class="custom-text-section" style="background-color: {{ section.settings.bg_color }};" id="new-pour">
  <div class="custom-text-section__container">
    {% if section.settings.heading != blank %}
      <h2 class="custom-text-section__heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="custom-text-section__text" style="color: {{ section.settings.text_color }};">
        {{ section.settings.text }}
      </div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a 
        href="{{ section.settings.button_url }}" 
        class="custom-text-section__btn" 
        style="background-color: {{ section.settings.button_bg }}; color: {{ section.settings.button_text }};"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Custom Centered Text",
  "tag": "section",
  "class": "section-custom-text",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEW & IMPROVED POUR"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We just upgraded our bottle! Now with individual snap-top closures, SmartMouth is easier than ever to open and use – no more assembly needed! Same 24-hour fresh breath, with just 2 rinses a day. Now with effortless convenience!"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#2b70c9"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom Centered Text"
    }
  ]
}
{% endschema %}