{%- style -%}
  .section-{{ section.id }}-wrapper {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Grid adjustments for spacing */
  .features-grid-{{ section.id }} {
    row-gap: 5rem;
  }

  @media screen and (min-width: 750px) {
    .features-grid-{{ section.id }} {
      row-gap: 6rem;
    }
  }

  .feature-block-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    padding: 0 1rem;
  }

  .feature-icon-wrapper-{{ section.id }} {
    width: 100%;
    max-width: 80px; /* Keeps the icons small and consistent */
    margin: 0 auto 2rem auto;
  }

  .feature-icon-wrapper-{{ section.id }} img {
    width: 100%;
    height: auto;
  }

  .feature-icon-{{ section.id }} {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .feature-block-{{ section.id }} h3 {
    color: {{ section.settings.text_color }};
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: clamp(1.6rem, 2vw, 1.8rem);
    font-weight: 600;
  }

  .feature-block-{{ section.id }} .rte {
    color: {{ section.settings.text_color }};
    opacity: 0.9; /* Slight transparency for body text to create visual hierarchy */
    font-size: 1.4rem;
    line-height: 1.6;
  }

  .feature-block-{{ section.id }} .rte p {
    margin: 0;
  }

  /* Placeholder styling */
  .feature-placeholder-wrapper {
    width: 80px;
    height: 80px;
    background-color: rgba(255, 255, 255, 0.2); /* Semi-transparent placeholder */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  
  .feature-placeholder-wrapper svg {
    width: 30px;
    height: 30px;
    fill: {{ section.settings.text_color }};
    opacity: 0.5;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-wrapper">
  <div class="page-width section-{{ section.id }}-padding">
    
    <div class="grid grid--1-col grid--2-col-tablet grid--{{ section.settings.columns_desktop }}-col-desktop features-grid-{{ section.id }}">
      
      {%- for block in section.blocks -%}
        <div class="grid__item" {{ block.shopify_attributes }}>
          <div class="feature-block-{{ section.id }}">
            
            <div class="feature-icon-wrapper-{{ section.id }}">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 200 | image_tag: 
                  class: 'feature-icon',
                  loading: 'lazy',
                  sizes: '60px'
                }}
              {%- else -%}
                <div class="feature-placeholder-wrapper">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>

            {%- if block.settings.heading != blank -%}
              <h3>{{ block.settings.heading }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Features Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#005aab"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}