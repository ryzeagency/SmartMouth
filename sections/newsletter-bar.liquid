{{ 'section-newsletter-banner.css' | asset_url | stylesheet_tag }}

<section class="newsletter-banner" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <div class="newsletter-banner__container">
    
    {% if section.settings.heading != blank %}
      <h2 class="newsletter-banner__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="newsletter-banner__text">
        {{ section.settings.text }}
      </div>
    {% endif %}

    {% if section.settings.show_form %}
      <div class="newsletter-banner__form-wrapper">
        {% form 'customer', class: 'newsletter-banner__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          {%- if form.posted_successfully? -%}
            <div class="newsletter-banner__success" tabindex="-1" autofocus>
              Thanks for subscribing! Keep an eye on your inbox.
            </div>
          {%- else -%}
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="newsletter-banner__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
              {% endif %}
              placeholder="Enter your email"
              required
            >
            <button type="submit" class="newsletter-banner__btn" name="commit" id="Subscribe">
              Subscribe
            </button>
          {%- endif -%}
        {% endform %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Newsletter Banner",
  "tag": "section",
  "class": "section-newsletter-banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0073c8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign up today for coupons, offers and updates!"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "At SmartMouth™, we love saving you from bad breath, but we also love saving you money."
    },
    {
      "type": "header",
      "content": "Email Form"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Show email input form",
      "info": "Displays a working Shopify newsletter sign-up field below the text.",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Newsletter Banner"
    }
  ]
}
{% endschema %}