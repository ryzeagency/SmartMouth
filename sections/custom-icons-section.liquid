{%- style -%}
  .section-{{ section.id }}-wrapper {
    background-color: {{ section.settings.bg_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .icons-dual-container-{{ section.id }} {
    text-align: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .icons-dual-heading-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 4rem;
  }

  /* Flexbox Grid for Icons */
  .icons-row-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  /* Mobile: 2 per row */
  .icon-item-{{ section.id }} {
    width: calc((100% - 3rem) / 2);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Tablet: 3 per row */
  @media screen and (min-width: 750px) {
    .icon-item-{{ section.id }} {
      width: calc((100% - 6rem) / 3);
    }
  }

  /* Desktop: Dynamic based on settings (3, 4, 5, or 6) */
  @media screen and (min-width: 990px) {
    .icon-item-{{ section.id }} {
      width: calc((100% - (({{ section.settings.columns_desktop }} - 1) * 3rem)) / {{ section.settings.columns_desktop }});
    }
  }

  .icon-image-{{ section.id }} {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Bottom Text */
  .icons-dual-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 3rem;
    opacity: 0.9;
  }

  .icons-dual-text-{{ section.id }} p {
    margin: 0;
  }

  /* Dual Buttons */
  .icons-dual-buttons-{{ section.id }} {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .icons-btn-{{ section.id }} {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border: 0;
    padding: 0 3rem;
    cursor: pointer;
    font: inherit;
    font-size: 1.2rem;
    font-weight: 700;
    text-decoration: none;
    min-height: 4.4rem;
    border-radius: 4rem; /* Pill shape */
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .icons-btn-{{ section.id }}:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }

  .btn-primary-{{ section.id }} {
    background-color: {{ section.settings.btn1_bg_color }};
    color: {{ section.settings.btn1_text_color }};
  }

  .btn-secondary-{{ section.id }} {
    background-color: {{ section.settings.btn2_bg_color }};
    color: {{ section.settings.btn2_text_color }};
  }

  /* Placeholder Styling */
  .placeholder-icon-wrapper {
    background-color: rgba(var(--color-foreground), 0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1 / 1;
  }
  .placeholder-icon-wrapper svg {
    width: 40%;
    height: 40%;
    fill: rgba(var(--color-foreground), 0.2);
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-wrapper">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="icons-dual-container-{{ section.id }}">
      
      {%- if section.settings.heading != blank -%}
        <h2 class="icons-dual-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="icons-row-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div class="icon-item-{{ section.id }}" {{ block.shopify_attributes }}>
              <div style="width: 100%; max-width: {{ block.settings.image_width }}px; margin: 0 auto;">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 300 }}" 
                       alt="{{ block.settings.image.alt | escape }}" 
                       class="icon-image-{{ section.id }}" 
                       loading="lazy" 
                       width="{{ block.settings.image.width }}" 
                       height="{{ block.settings.image.height }}">
                {%- else -%}
                  <div class="placeholder-icon-wrapper">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="icons-dual-text-{{ section.id }} rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      <div class="icons-dual-buttons-{{ section.id }}">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_link | default: '#' }}" class="icons-btn-{{ section.id }} btn-primary-{{ section.id }}">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link | default: '#' }}" class="icons-btn-{{ section.id }} btn-secondary-{{ section.id }}">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icons with Dual Buttons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Key findings from the study include:"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Columns on desktop",
      "default": 6
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Bottom Text Content",
      "default": "<p>Sign up to order for your dental office or request patient handouts and samples of SmartMouth products.</p>"
    },
    {
      "type": "header",
      "content": "Button 1 (Left)"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "New Office Request Form"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "color",
      "id": "btn1_bg_color",
      "label": "Button 1 Background",
      "default": "#0076cb"
    },
    {
      "type": "color",
      "id": "btn1_text_color",
      "label": "Button 1 Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 2 (Right)"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "Returning Office Form"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "color",
      "id": "btn2_bg_color",
      "label": "Button 2 Background",
      "default": "#008037"
    },
    {
      "type": "color",
      "id": "btn2_text_color",
      "label": "Button 2 Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Colors & Padding"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 200,
          "step": 5,
          "unit": "px",
          "label": "Max Icon Width",
          "default": 120
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icons with Dual Buttons",
      "blocks": [
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" }
      ]
    }
  ]
}
{% endschema %}