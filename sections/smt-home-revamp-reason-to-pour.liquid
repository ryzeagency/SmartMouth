{% liquid
  assign shop_all_link = section.settings.button_link | default: routes.all_products_collection_url
%}

<section class="hr-reasons" aria-labelledby="ReasonsHeading-{{ section.id }}">
  <div class="hr-reasons__container">
    {% if section.settings.heading != blank %}
      <h2 class="hr-reasons__heading" id="ReasonsHeading-{{ section.id }}">
        {{ section.settings.heading_prefix | escape }}
        <span>{{ section.settings.heading_accent | escape }}</span>
        {{ section.settings.heading_suffix | escape }}
      </h2>
    {% endif %}

    <div class="hr-reasons__grid" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign card_product = block.settings.product
          assign card_image = block.settings.image
          if card_image == blank and card_product != blank
            assign card_image = card_product.featured_image
          endif

          assign card_title = block.settings.custom_title
          if card_title == blank and card_product != blank
            assign card_title = card_product.title
          endif

          assign card_link = block.settings.custom_link
          if card_link == blank and card_product != blank
            assign card_link = card_product.url
          endif
          if card_link == blank
            assign card_link = shop_all_link
          endif

          assign fallback_alt = card_title | default: block.settings.badge_text
        %}

        <article class="hr-reasons__card" role="listitem" {{ block.shopify_attributes }}>
          <a class="hr-reasons__card-link" href="{{ card_link }}">
            <div class="hr-reasons__media">
              {% if card_image != blank %}
                {{
                  card_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '320, 480, 640, 800, 1000, 1200',
                    sizes: '(min-width: 750px) 16.3vw, 41vw',
                    loading: 'lazy',
                    alt: fallback_alt
                }}
                {% if block.settings.badge_text != blank %}
                  <span
                    class="hr-reasons__badge"
                    style="--badge-bg: {{ block.settings.badge_color }}; --badge-text: {{ block.settings.badge_text_color }};"
                  >
                    {{ block.settings.badge_text | escape }}
                  </span>
                {% endif %}
              {% else %}
                <span
                  class="hr-reasons__fallback hr-reasons__fallback--{{ block.settings.fallback_card }}"
                  role="img"
                  aria-label="{{ fallback_alt | escape }}"
                ></span>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="hr-reasons__footer">
        <a class="hr-reasons__shop-all" href="{{ shop_all_link }}">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --hr-reasons-bg: {{ section.settings.background_color }};
    --hr-reasons-text: {{ section.settings.text_color }};
    --hr-reasons-accent: {{ section.settings.accent_color }};
    --hr-reasons-link: {{ section.settings.link_color }};
  }

  #shopify-section-{{ section.id }} .hr-reasons {
    color: var(--hr-reasons-text);
    background: var(--hr-reasons-bg);
  }

  #shopify-section-{{ section.id }} .hr-reasons__container {
    width: 85vw;
    margin: 0 auto;
    padding: 6.05vw 0 6.2vw;
  }

  #shopify-section-{{ section.id }} .hr-reasons__heading {
    margin: 0 0 4.28vw;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.32vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1.1;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .hr-reasons__heading span {
    color: var(--hr-reasons-accent);
  }

  #shopify-section-{{ section.id }} .hr-reasons__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.55vw;
    width: 70vw;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .hr-reasons__card,
  #shopify-section-{{ section.id }} .hr-reasons__card-link {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .hr-reasons__card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .hr-reasons__media {
    display: grid;
    width: 100%;
    aspect-ratio: .95;
    overflow: hidden;
    background: rgba(var(--color-foreground), .05);
  }

  #shopify-section-{{ section.id }} .hr-reasons__media > * {
    grid-area: 1 / 1;
  }

  #shopify-section-{{ section.id }} .hr-reasons__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .hr-reasons__badge {
    z-index: 1;
    align-self: start;
    justify-self: start;
    min-width: 9.3vw;
    padding: .58vw 1.3vw;
    color: var(--badge-text);
    background: var(--badge-bg);
    border-radius: 0 0 .24vw 0;
    font-size: .91vw;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .hr-reasons__fallback {
    display: block;
    width: 100%;
    height: 100%;
    background-image: url("{{ 'fbf92fb8-e539-46b1-a8c5-a7e3de17e528.png' | asset_url }}");
    background-repeat: no-repeat;
    background-size: 100vw 43.02vw;
  }

  #shopify-section-{{ section.id }} .hr-reasons__fallback--1 { background-position: -15.04vw -12.65vw; }
  #shopify-section-{{ section.id }} .hr-reasons__fallback--2 { background-position: -32.96vw -12.65vw; }
  #shopify-section-{{ section.id }} .hr-reasons__fallback--3 { background-position: -50.83vw -12.65vw; }
  #shopify-section-{{ section.id }} .hr-reasons__fallback--4 { background-position: -68.65vw -12.65vw; }

  #shopify-section-{{ section.id }} .hr-reasons__card-title {
    margin: .82vw 0 0;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1vw;
    font-style: var(--font-body-style);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.18;
  }

  #shopify-section-{{ section.id }} .hr-reasons__footer {
    margin-top: 2.1vw;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .hr-reasons__shop-all {
    color: var(--hr-reasons-link);
    font-size: 1.22vw;
    font-weight: 800;
    line-height: 1;
    text-decoration: underline;
    text-decoration-thickness: .07vw;
    text-underline-offset: .17vw;
    text-transform: uppercase;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .hr-reasons__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 5vw 3vw;
      width: 85vw;
    }

    #shopify-section-{{ section.id }} .hr-reasons__fallback {
      background-image: none;
      background-color: rgba(var(--color-foreground), .06);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hr-reasons__container {
      padding: 14vw 0;
    }

    #shopify-section-{{ section.id }} .hr-reasons__heading {
      margin-bottom: 10vw;
      font-size: 6.5vw;
    }

    #shopify-section-{{ section.id }} .hr-reasons__card-title {
      margin-top: 2.3vw;
      font-size: 3.8vw;
    }

    #shopify-section-{{ section.id }} .hr-reasons__badge {
      min-width: 27vw;
      padding: 1.8vw 3vw;
      border-radius: 0 0 1vw 0;
      font-size: 3vw;
    }

    #shopify-section-{{ section.id }} .hr-reasons__footer {
      margin-top: 8vw;
    }

    #shopify-section-{{ section.id }} .hr-reasons__shop-all {
      font-size: 4.3vw;
      text-decoration-thickness: .25vw;
      text-underline-offset: .6vw;
    }
  }
</style>

{% schema %}
{
  "name": "Reason to Pour",
  "tag": "section",
  "class": "section section-home-revamp-reasons",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading_prefix", "label": "Heading before accent", "default": "What’s your" },
    { "type": "text", "id": "heading_accent", "label": "Accent text", "default": "reason" },
    { "type": "text", "id": "heading_suffix", "label": "Heading after accent", "default": "to pour?" },
    { "type": "text", "id": "heading", "label": "Accessibility heading label", "default": "What’s your reason to pour?" },
    { "type": "header", "content": "Shop all link" },
    { "type": "text", "id": "button_label", "label": "Link label", "default": "SHOP ALL PRODUCTS" },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#062342" },
    { "type": "color", "id": "accent_color", "label": "Heading accent", "default": "#8FD7CD" },
    { "type": "color", "id": "link_color", "label": "Shop all link", "default": "#1F568D" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "custom_title", "label": "Custom title" },
        { "type": "url", "id": "custom_link", "label": "Custom link" },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "BAD BREATH" },
        { "type": "color", "id": "badge_color", "label": "Badge background", "default": "#008244" },
        { "type": "color", "id": "badge_text_color", "label": "Badge text", "default": "#FFFFFF" },
        {
          "type": "select",
          "id": "fallback_card",
          "label": "Mockup fallback card",
          "default": "1",
          "options": [
            { "value": "1", "label": "Original / Bad Breath" },
            { "value": "2", "label": "Dry Mouth" },
            { "value": "3", "label": "Clinical / Oral Health" },
            { "value": "4", "label": "Evening / Night Time" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reason to Pour",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "custom_title": "SmartMouth™ Original Liposomal Evening Mouthwash",
            "badge_text": "BAD BREATH",
            "badge_color": "#008244",
            "fallback_card": "1"
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_title": "SmartMouth™ Dry Mouth Activated Mouthwash",
            "badge_text": "DRY MOUTH",
            "badge_color": "#5E00B8",
            "fallback_card": "2"
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_title": "SmartMouth™ Clinical Activated Mouthwash",
            "badge_text": "ORAL HEALTH",
            "badge_color": "#245A8D",
            "fallback_card": "3"
          }
        },
        {
          "type": "product",
          "settings": {
            "custom_title": "SmartMouth™ Advanced Liposomal Evening Mouthwash",
            "badge_text": "NIGHT TIME",
            "badge_color": "#9C91D3",
            "fallback_card": "4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
