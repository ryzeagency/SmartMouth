<section class="faq-accordion" aria-labelledby="FaqAccordionHeading-{{ section.id }}">
  <div class="faq-accordion__container">
    <header class="faq-accordion__header">
      {% if section.settings.eyebrow != blank %}
        <p class="faq-accordion__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="FaqAccordionHeading-{{ section.id }}" class="faq-accordion__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="faq-accordion__panel">
        {% for block in section.blocks %}
          <div class="faq-accordion__item" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="faq-accordion__toggle"
              id="FaqToggle-{{ section.id }}-{{ forloop.index }}"
              aria-expanded="false"
              aria-controls="FaqContent-{{ section.id }}-{{ forloop.index }}"
            >
              <span class="faq-accordion__question">{{ block.settings.question | escape }}</span>
              <span class="faq-accordion__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
                </svg>
              </span>
            </button>

            <div
              class="faq-accordion__content"
              id="FaqContent-{{ section.id }}-{{ forloop.index }}"
              role="region"
              aria-labelledby="FaqToggle-{{ section.id }}-{{ forloop.index }}"
              hidden
            >
              <div class="faq-accordion__answer">
                {% if block.settings.answer_image != blank %}
                  <div class="faq-accordion__answer-image">
                    {{
                      block.settings.answer_image
                      | image_url: width: 2000
                      | image_tag:
                        widths: '600, 900, 1200, 1600, 2000',
                        sizes: '(min-width: 750px) 66vw, 78vw',
                        loading: 'lazy',
                        alt: block.settings.answer_image_alt
                    }}
                  </div>
                {% endif %}

                {% if block.settings.answer != blank %}
                  <div class="faq-accordion__answer-text rte">{{ block.settings.answer }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --faq-body-size: 1vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-block: {{ section.settings.padding_top }}vw {{ section.settings.padding_bottom }}vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__container {
    width: {{ section.settings.container_width }}vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .faq-accordion__header {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .faq-accordion__eyebrow {
    margin: 0 0 1.25vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.45vw;
    font-style: var(--font-body-style);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .faq-accordion__heading {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading-family);
    font-size: 2.55vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .faq-accordion__panel {
    box-sizing: border-box;
    margin-top: 3vw;
    padding: 1vw 2.6vw;
    border: 0.06vw solid {{ section.settings.panel_border_color }};
    border-radius: {{ section.settings.panel_radius }}vw;
    background: {{ section.settings.panel_background }};
  }

  #shopify-section-{{ section.id }} .faq-accordion__item {
    border-bottom: 0.06vw solid {{ section.settings.divider_color }};
  }

  #shopify-section-{{ section.id }} .faq-accordion__item:last-child {
    border-bottom: 0;
  }

  #shopify-section-{{ section.id }} .faq-accordion__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2vw;
    width: 100%;
    margin: 0;
    padding: 1.5vw 0;
    border: 0;
    background: transparent;
    color: {{ section.settings.question_color }};
    font-family: var(--font-body-family);
    font-size: 1.15vw;
    font-style: var(--font-body-style);
    font-weight: 700;
    line-height: 1.25;
    text-align: left;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .faq-accordion__toggle:focus-visible {
    outline: 0.15vw solid {{ section.settings.accent_color }};
    outline-offset: 0.3vw;
    border-radius: 0.3vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__icon {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 2.2vw;
    height: 2.2vw;
    border-radius: 50%;
    background: {{ section.settings.icon_background }};
    color: {{ section.settings.accent_color }};
    transition: transform 250ms ease, background 250ms ease;
  }

  #shopify-section-{{ section.id }} .faq-accordion__icon svg {
    width: 1vw;
    height: 1vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__toggle[aria-expanded='true'] .faq-accordion__icon {
    transform: rotate(45deg);
  }

  #shopify-section-{{ section.id }} .faq-accordion__content {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer {
    padding: 0 8vw 1.7vw 0;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-image {
    margin-bottom: 1.2vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.55vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-text {
    color: {{ section.settings.answer_color }};
    font-family: var(--font-body-family);
    font-size: var(--faq-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-text > * {
    margin-block: 0;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-text > * + * {
    margin-top: 0.8vw;
  }

  #shopify-section-{{ section.id }} .faq-accordion__answer-text a {
    color: {{ section.settings.accent_color }};
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --faq-body-size: 4vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion {
      padding-block: {{ section.settings.mobile_padding_top }}vw {{ section.settings.mobile_padding_bottom }}vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__container {
      width: 88vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__eyebrow {
      margin-bottom: 3vw;
      font-size: 4.5vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__heading {
      font-size: 6.5vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__panel {
      margin-top: 8vw;
      padding: 2vw 5vw;
      border-width: 0.25vw;
      border-radius: {{ section.settings.panel_radius | times: 2.5 }}vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__item {
      border-bottom-width: 0.25vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__toggle {
      gap: 5vw;
      padding: 5vw 0;
      font-size: 4.4vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__icon {
      width: 8vw;
      height: 8vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__icon svg {
      width: 3.6vw;
      height: 3.6vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__answer {
      padding: 0 0 5.5vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__answer-image {
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__answer-image img {
      border-radius: 2vw;
    }

    #shopify-section-{{ section.id }} .faq-accordion__answer-text > * + * {
      margin-top: 3vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .faq-accordion__icon {
      transition: none;
    }
  }
</style>

<script>
  (function () {
    var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionEl) return;

    function initFaqAccordion() {
      var toggles = sectionEl.querySelectorAll('.faq-accordion__toggle');
      var allowMultiple = {{ section.settings.allow_multiple | json }};

      toggles.forEach(function (toggle) {
        if (toggle.dataset.faqBound) return;
        toggle.dataset.faqBound = 'true';

        toggle.addEventListener('click', function () {
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          var content = document.getElementById(toggle.getAttribute('aria-controls'));

          if (!allowMultiple) {
            toggles.forEach(function (other) {
              if (other === toggle) return;
              other.setAttribute('aria-expanded', 'false');
              var otherContent = document.getElementById(other.getAttribute('aria-controls'));
              if (otherContent) otherContent.hidden = true;
            });
          }

          toggle.setAttribute('aria-expanded', String(!expanded));
          if (content) content.hidden = expanded;
        });
      });
    }

    initFaqAccordion();
    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail.sectionId === '{{ section.id }}') initFaqAccordion();
    });
  })();
</script>

