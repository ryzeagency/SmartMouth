{%- liquid
  assign facebook_url = section.settings.social_facebook | default: settings.social_facebook_link
  assign linkedin_url = section.settings.social_linkedin | default: settings.social_linkedin_link
  assign instagram_url = section.settings.social_instagram | default: settings.social_instagram_link
  assign tiktok_url = section.settings.social_tiktok | default: settings.social_tiktok_link
-%}

<style>
  #shopify-section-{{ section.id }} .sm-footer {
    --sm-footer-background: {{ section.settings.bg_color }};
    --sm-footer-foreground: {{ section.settings.text_color }};
    background: var(--sm-footer-background);
    color: var(--sm-footer-foreground);
    padding-block: {{ section.settings.padding_top | divided_by: 19.2 }}vw {{ section.settings.padding_bottom | divided_by: 19.2 }}vw;
  }

  #shopify-section-{{ section.id }} .sm-footer__inner {
    display: grid;
    grid-template-columns: 39vw minmax(0, 1fr);
    column-gap: 3vw;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .sm-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-self: start;
    width: 25vw;
    padding-top: 3.8vw;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .sm-footer__logo {
    display: block;
    width: min(var(--sm-footer-logo-width), 100%);
    max-width: 100%;
    margin: 0;
    height: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .sm-footer__shop-name {
    margin: 0;
    color: var(--sm-footer-foreground);
    font-size: 2.5vw;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .sm-footer__brand-text {
    width: 100%;
    margin-top: 1.25vw;
    color: var(--sm-footer-foreground);
    font-size: 0.72vw;
    line-height: 1.5;
    opacity: 0.65;
  }

  #shopify-section-{{ section.id }} .sm-footer__brand-text p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .sm-footer__socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.35vw;
    padding: 0;
    margin: 4.15vw 0 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .sm-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.05vw;
    aspect-ratio: 1;
    color: var(--sm-footer-foreground);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  #shopify-section-{{ section.id }} .sm-footer__social-link:hover {
    opacity: 0.65;
    transform: translateY(-0.12vw);
  }

  #shopify-section-{{ section.id }} .sm-footer__social-link:focus-visible,
  #shopify-section-{{ section.id }} .sm-footer__link:focus-visible {
    outline: 0.1vw solid currentColor;
    outline-offset: 0.22vw;
  }

  #shopify-section-{{ section.id }} .sm-footer__social-link svg {
    display: block;
    width: 100%;
    fill: currentColor;
  }

  #shopify-section-{{ section.id }} .sm-footer__copyright {
    margin: 1.55vw 0 0;
    color: var(--sm-footer-foreground);
    font-size: 0.69vw;
    line-height: 1.4;
    opacity: 0.45;
  }

  #shopify-section-{{ section.id }} .sm-footer__menus {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .sm-footer__heading {
    margin: 0 0 2.45vw;
    color: var(--sm-footer-foreground);
    font-size: 1.25vw;
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .sm-footer__menu-grid {
    display: grid;
    grid-template-columns: 0.9fr 1fr 0.8fr;
    column-gap: 3.35vw;
  }

  #shopify-section-{{ section.id }} .sm-footer__menu-list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .sm-footer__menu-item + .sm-footer__menu-item {
    margin-top: 2.03vw;
  }

  #shopify-section-{{ section.id }} .sm-footer__link {
    display: inline-block;
    color: var(--sm-footer-foreground);
    font-size: 0.75vw;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.015vw;
    text-decoration: none;
    text-transform: uppercase;
    text-underline-offset: 0.2vw;
    transition: opacity 180ms ease;
  }

  #shopify-section-{{ section.id }} .sm-footer__link:hover {
    opacity: 0.58;
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar {
    background: {{ section.settings.bar_bg_color }};
    color: {{ section.settings.bar_text_color }};
    padding-block: {{ section.settings.bar_padding_top | divided_by: 19.2 }}vw {{ section.settings.bar_padding_bottom | divided_by: 19.2 }}vw;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6vw 2vw;
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar__copyright,
  #shopify-section-{{ section.id }} .sm-footer-bar__credit {
    margin: 0;
    font-size: 0.72vw;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar__credit a {
    color: inherit;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2vw;
    transition: opacity 180ms ease;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar__credit a:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .sm-footer-bar__credit a:focus-visible {
    outline: 0.1vw solid currentColor;
    outline-offset: 0.22vw;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .sm-footer {
      padding-block: 8vw 10vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__inner {
      grid-template-columns: 1fr;
      row-gap: 10vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__brand {
      width: 100%;
      padding-top: 0;
    }

    #shopify-section-{{ section.id }} .sm-footer__logo {
      width: min(var(--sm-footer-logo-width-mobile), 52vw);
    }

    #shopify-section-{{ section.id }} .sm-footer__shop-name {
      font-size: 7vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__brand-text {
      max-width: 70vw;
      margin-top: 3vw;
      font-size: 2.3vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__socials {
      gap: 4.5vw;
      margin-top: 7vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__social-link {
      width: 3.6vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__copyright {
      margin-top: 3.5vw;
      font-size: 2.2vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__heading {
      margin-bottom: 5vw;
      font-size: 3.6vw;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .sm-footer__menu-grid {
      column-gap: 5vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__menu-item + .sm-footer__menu-item {
      margin-top: 3.3vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__link {
      font-size: 2vw;
      letter-spacing: 0.04vw;
    }

    #shopify-section-{{ section.id }} .sm-footer-bar {
      padding-block: 2.5vw;
    }

    #shopify-section-{{ section.id }} .sm-footer-bar__copyright,
    #shopify-section-{{ section.id }} .sm-footer-bar__credit {
      font-size: 2vw;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .sm-footer {
      padding-block: 12vw 14vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__inner {
      row-gap: 13vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__logo {
      width: min(var(--sm-footer-logo-width-mobile), 40vw);
    }

    #shopify-section-{{ section.id }} .sm-footer__brand-text {
      max-width: 80vw;
      margin-top: 5vw;
      font-size: 3.3vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__socials {
      gap: 6vw;
      margin-top: 9vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__social-link {
      width: 4vw;
      height: 4vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__social-link svg {
      height: 100%;
    }

    #shopify-section-{{ section.id }} .sm-footer__copyright {
      margin-top: 4.5vw;
      font-size: 3.1vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__heading {
      margin-bottom: 7vw;
      font-size: 5.2vw;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .sm-footer__menu-grid {
      grid-template-columns: 1fr;
      row-gap: 9vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__menu-item + .sm-footer__menu-item {
      margin-top: 4.8vw;
    }

    #shopify-section-{{ section.id }} .sm-footer__link {
      font-size: 3.5vw;
      letter-spacing: 0.06vw;
    }

    #shopify-section-{{ section.id }} .sm-footer-bar {
      padding-block: 4vw;
    }

    #shopify-section-{{ section.id }} .sm-footer-bar__inner {
      flex-direction: column;
      justify-content: center;
      gap: 1.5vw;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .sm-footer-bar__copyright,
    #shopify-section-{{ section.id }} .sm-footer-bar__credit {
      font-size: 3vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .sm-footer__social-link,
    #shopify-section-{{ section.id }} .sm-footer__link,
    #shopify-section-{{ section.id }} .sm-footer-bar__credit a {
      transition: none;
    }
  }
</style>

<footer class="sm-footer" aria-label="Site footer">
  <div class="sm-footer__inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'brand' -%}
          <div
            class="sm-footer__brand"
            style="--sm-footer-logo-width: {{ block.settings.logo_width | divided_by: 19.2 }}vw; --sm-footer-logo-width-mobile: {{ block.settings.logo_width_mobile }}vw;"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.logo != blank -%}
              <img
                class="sm-footer__logo"
                src="{{ block.settings.logo | image_url: width: 800 }}"
                srcset="
                  {{ block.settings.logo | image_url: width: 350 }} 350w,
                  {{ block.settings.logo | image_url: width: 500 }} 500w,
                  {{ block.settings.logo | image_url: width: 700 }} 700w,
                  {{ block.settings.logo | image_url: width: 800 }} 800w
                "
                sizes="(min-width: 990px) {{ block.settings.logo_width | divided_by: 19.2 }}vw, {{ block.settings.logo_width_mobile }}vw"
                width="{{ block.settings.logo.width }}"
                height="{{ block.settings.logo.height }}"
                alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <h2 class="sm-footer__shop-name">{{ shop.name | escape }}</h2>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="sm-footer__brand-text rte">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if facebook_url != blank or linkedin_url != blank or instagram_url != blank or tiktok_url != blank -%}
              <ul class="sm-footer__socials" role="list" aria-label="Social media">
                {%- if facebook_url != blank -%}
                  <li>
                    <a class="sm-footer__social-link" href="{{ facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
                      <svg aria-hidden="true" viewBox="0 0 320 512"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if linkedin_url != blank -%}
                  <li>
                    <a class="sm-footer__social-link" href="{{ linkedin_url }}" target="_blank" rel="noopener" aria-label="LinkedIn">
                      <svg aria-hidden="true" viewBox="0 0 448 512"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if instagram_url != blank -%}
                  <li>
                    <a class="sm-footer__social-link" href="{{ instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
                      <svg aria-hidden="true" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if tiktok_url != blank -%}
                  <li>
                    <a class="sm-footer__social-link" href="{{ tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
                      <svg aria-hidden="true" viewBox="0 0 448 512"><path d="M448 209.91a210.06 210.06 0 0 1-122.77-39.25V349.38A162.55 162.55 0 1 1 185 188.31v89.89a74.62 74.62 0 1 0 52.23 71.18V0l88 0a121.18 121.18 0 0 0 1.86 22.17h0A122.18 122.18 0 0 0 381 102.39a121.43 121.43 0 0 0 67 20.14Z"/></svg>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            {%- endif -%}

            {%- if section.settings.show_brand_copyright -%}
              <p class="sm-footer__copyright">
                &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name | default: shop.name | escape }}. {{ section.settings.copyright_text | escape }}
              </p>
            {%- endif -%}
          </div>

        {%- when 'multi_menu' -%}
          <nav class="sm-footer__menus" aria-label="{{ block.settings.heading | default: 'Footer links' | escape }}" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="sm-footer__heading">{{ block.settings.heading | escape }}</h2>
            {%- endif -%}

            <div class="sm-footer__menu-grid">
              {%- for menu_index in (1..3) -%}
                {%- liquid
                  case menu_index
                    when 1
                      assign footer_menu = block.settings.menu_1
                    when 2
                      assign footer_menu = block.settings.menu_2
                    when 3
                      assign footer_menu = block.settings.menu_3
                  endcase
                -%}
                {%- if footer_menu != blank -%}
                  <ul class="sm-footer__menu-list" role="list">
                    {%- for link in footer_menu.links -%}
                      <li class="sm-footer__menu-item">
                        <a class="sm-footer__link" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <div aria-hidden="true"></div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </nav>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</footer>

{%- if section.settings.show_bottom_bar -%}
  <div class="sm-footer-bar">
    <div class="sm-footer-bar__inner">
      <p class="sm-footer-bar__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name | default: shop.name | escape }}. {{ section.settings.copyright_text | escape }}
      </p>
      {%- if section.settings.credit_name != blank -%}
        <p class="sm-footer-bar__credit">
          {{ section.settings.credit_prefix | escape }}
          {%- if section.settings.credit_url != blank %}
            <a href="{{ section.settings.credit_url }}" target="_blank" rel="noopener">{{ section.settings.credit_name | escape }}</a>
          {%- else %}
            {{ section.settings.credit_name | escape }}
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "SmartMouth Footer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Social media links",
      "info": "Section links override the theme's social links. Leave blank to use the theme settings."
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_name",
      "label": "Copyright name",
      "default": "SmartMouth™"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All Rights Reserved."
    },
    {
      "type": "checkbox",
      "id": "show_brand_copyright",
      "label": "Also show copyright in the logo column",
      "default": false,
      "info": "The copyright now lives in the slim bottom bar. Enable this to show it in both places."
    },
    {
      "type": "header",
      "content": "Bottom bar",
      "info": "Slim strip below the footer with the copyright and agency credit."
    },
    {
      "type": "checkbox",
      "id": "show_bottom_bar",
      "label": "Show bottom bar",
      "default": true
    },
    {
      "type": "text",
      "id": "credit_prefix",
      "label": "Credit text",
      "default": "Built by"
    },
    {
      "type": "text",
      "id": "credit_name",
      "label": "Credit link label",
      "default": "Ryze Agency"
    },
    {
      "type": "url",
      "id": "credit_url",
      "label": "Credit link URL",
      "info": "e.g. https://ryzeagency.com"
    },
    {
      "type": "color",
      "id": "bar_bg_color",
      "label": "Bar background",
      "default": "#205085"
    },
    {
      "type": "color",
      "id": "bar_text_color",
      "label": "Bar text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "bar_padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Bar top padding at 1920px",
      "default": 14
    },
    {
      "type": "range",
      "id": "bar_padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Bar bottom padding at 1920px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Top padding at 1920px",
      "default": 85
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding at 1920px",
      "default": 145
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Logo and socials",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 100,
          "max": 500,
          "step": 5,
          "unit": "px",
          "label": "Logo width at 1920px",
          "default": 325
        },
        {
          "type": "range",
          "id": "logo_width_mobile",
          "min": 30,
          "max": 80,
          "step": 1,
          "unit": "%",
          "label": "Mobile logo width",
          "default": 62
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Optional brand text"
        }
      ]
    },
