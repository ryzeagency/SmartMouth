{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .split-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .split-header-{{ section.id }} .h1 {
    margin-bottom: 1.5rem;
  }

  .split-header-{{ section.id }} .rte {
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.6rem;
  }

  .split-image-wrapper-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 300px;
    border-radius: var(--media-radius);
    overflow: hidden;
    display: flex;
  }

  .split-image-wrapper-{{ section.id }} img {
    height: auto;
    width: 100%;
  }

  .split-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .split-text-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 2rem 0;
  }

  /* Desktop Layout Ordering & Padding */
  @media screen and (min-width: 750px) {
    /* If image is on the RIGHT */
    .split-layout-right-{{ section.id }} .split-image-column {
      order: 2;
    }
    .split-layout-right-{{ section.id }} .split-text-column {
      order: 1;
    }
    
    /* Dynamic padding so text isn't glued to the image */
    .split-layout-left-{{ section.id }} .split-text-content-{{ section.id }} {
      padding-left: 3rem;
    }
    .split-layout-right-{{ section.id }} .split-text-content-{{ section.id }} {
      padding-right: 3rem;
    }
  }

  .split-text-content-{{ section.id }} .h2 {
    margin-top: 0;
    margin-bottom: 2rem;
    font-weight: bold;
  }

  .split-text-content-{{ section.id }} .rte p {
    margin-bottom: 1.5rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.6;
  }

  /* Placeholder styling */
  .placeholder-svg-wrapper {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: rgba(var(--color-foreground), 0.04);
  }
  .placeholder-svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: rgba(var(--color-foreground), 0.2);
  }
{%- endstyle -%}

<div class="split-section section-{{ section.id }}-padding page-width">
  
  {%- if section.settings.main_title != blank or section.settings.main_subtext != blank -%}
    <div class="split-header-{{ section.id }}">
      {%- if section.settings.main_title != blank -%}
        <h2 class="h2"><strong>{{ section.settings.main_title }}</strong></h2>
      {%- endif -%}
      {%- if section.settings.main_subtext != blank -%}
        <div class="rte">{{ section.settings.main_subtext }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="grid grid--1-col grid--2-col-tablet split-layout-{{ section.settings.layout }}-{{ section.id }}">
    
    <div class="grid__item split-image-column">
      <div class="split-image-wrapper-{{ section.id }}">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag: 
            class: 'split-image',
            loading: 'lazy',
            sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="placeholder-svg-wrapper">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="grid__item split-text-column">
      <div class="split-text-content-{{ section.id }}">
        {%- if section.settings.right_heading != blank -%}
          <h2 class="h2">{{ section.settings.right_heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.right_text != blank -%}
          <div class="rte">
            {{ section.settings.right_text }}
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Split Image & Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Top Header"
    },
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Title"
    },
    {
      "type": "richtext",
      "id": "main_subtext",
      "label": "Main Subtext"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image placement on desktop",
      "options": [
        {
          "value": "left",
          "label": "Image on left"
        },
        {
          "value": "right",
          "label": "Image on right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Image Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "right_text",
      "label": "Text Content"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Split Image & Text"
    }
  ]
}
{% endschema %}