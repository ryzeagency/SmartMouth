<section class="about-standards" aria-labelledby="AboutStandardsHeading-{{ section.id }}">
  <div class="about-standards__inner">
    {%- if section.settings.heading != blank -%}
      <header class="about-standards__header">
        <h2 class="about-standards__heading" id="AboutStandardsHeading-{{ section.id }}">
          {{- section.settings.heading | escape -}}
        </h2>
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="about-standards__grid" role="list">
        {%- for block in section.blocks -%}
          <article class="about-standards__item" role="listitem" {{ block.shopify_attributes }}>
            <div
              class="about-standards__icon-wrap"
              style="--about-standards-icon-width: {{ block.settings.icon_width }}vw;"
            >
              {%- if block.settings.icon != blank -%}
                <img
                  class="about-standards__icon"
                  src="{{ block.settings.icon | image_url: width: 400 }}"
                  srcset="
                    {{ block.settings.icon | image_url: width: 160 }} 160w,
                    {{ block.settings.icon | image_url: width: 240 }} 240w,
                    {{ block.settings.icon | image_url: width: 400 }} 400w
                  "
                  sizes="(min-width: 750px) {{ block.settings.icon_width }}vw, 18vw"
                  width="{{ block.settings.icon.width }}"
                  height="{{ block.settings.icon.height }}"
                  alt="{{ block.settings.icon.alt | default: block.settings.title | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3>{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p>{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --about-body-size: 1vw;
    --about-body-size-mobile: 3.5vw;
    --about-standards-background: {{ section.settings.background_color }};
    --about-standards-text: {{ section.settings.text_color }};
    --about-standards-banner: {{ section.settings.heading_background }};
    --about-standards-banner-text: {{ section.settings.heading_color }};
  }

  #shopify-section-{{ section.id }} .about-standards {
    padding: 3.55vw 0 4.65vw;
    color: var(--about-standards-text);
    background: var(--about-standards-background);
  }

  #shopify-section-{{ section.id }} .about-standards__inner {
    width: 85vw;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .about-standards__header {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .about-standards__heading {
    display: inline-block;
    margin: 0;
    padding: 0.8vw 1.05vw 0.95vw;
    color: var(--about-standards-banner-text);
    background: var(--about-standards-banner);
    font-family: var(--font-heading-family);
    font-size: 2.45vw;
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .about-standards__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, minmax(0, 1fr));
    align-items: start;
    gap: 2vw;
    margin-top: 2.55vw;
  }

  #shopify-section-{{ section.id }} .about-standards__item {
    min-width: 0;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .about-standards__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--about-standards-icon-width);
    max-width: 100%;
    aspect-ratio: 1;
    margin: 0 auto 1.2vw;
  }

  #shopify-section-{{ section.id }} .about-standards__icon {
    display: block;
    width: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .about-standards__item h3 {
    margin: 0 0 0.3vw;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: 1.35vw;
    font-style: var(--font-body-style);
    font-weight: 500;
    line-height: 1.15;
  }

  #shopify-section-{{ section.id }} .about-standards__item p {
    max-width: 17vw;
    margin: 0 auto;
    color: inherit;
    font-family: var(--font-body-family);
    font-size: var(--about-body-size);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: 1.25;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .about-standards {
      padding: 12vw 0 14vw;
    }

    #shopify-section-{{ section.id }} .about-standards__heading {
      padding: 2.5vw 3vw 3vw;
      font-size: 6.5vw;
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .about-standards__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12vw 6vw;
      margin-top: 12vw;
    }

    #shopify-section-{{ section.id }} .about-standards__icon-wrap {
      width: 18vw;
      margin-bottom: 5vw;
    }

    #shopify-section-{{ section.id }} .about-standards__item h3 {
      margin-bottom: 2vw;
      font-size: 4vw;
      font-weight: 700;
    }

    #shopify-section-{{ section.id }} .about-standards__item p {
      max-width: none;
      font-size: var(--about-body-size-mobile);
      line-height: 1.4;
    }
  }
</style>

{% schema %}
{
  "name": "About Product Standards",
  "tag": "section",
  "class": "section section-about-product-standards",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every SmartMouth product. Every time."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#24588E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and icons",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_background",
      "label": "Heading background",
      "default": "#8DD4CA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "standard",
      "name": "Product standard",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "range",
          "id": "icon_width",
          "min": 4,
          "max": 9,
          "step": 0.5,
          "unit": "vw",
          "label": "Desktop icon width",
          "default": 5.5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Zero alcohol"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "No burn, no dryness — in every formula"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Product Standards",
      "category": "About Revamp",
      "blocks": [
        {
          "type": "standard",
          "settings": {
            "title": "Zero alcohol",
            "description": "No burn, no dryness — in every formula"
          }
        },
        {
          "type": "standard",
          "settings": {
            "title": "Paraben-free",
            "description": "Clean formulas you can use every day"
          }
        },
        {
          "type": "standard",
          "settings": {
            "title": "Safe for kids 6+",
            "description": "Safe for the whole family,,"
          }
        },
        {
          "type": "standard",
          "settings": {
            "title": "Dentist developed",
            "description": "Recommended by dental professionals nationwide"
          }
        }
      ]
    }
  ]
}
{% endschema %}
