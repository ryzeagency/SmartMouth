<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --teal:#00897B;--teal-d:#005A52;--teal-l:#E0F5F3;--teal-m:#B2E0DA;
  --navy:#0D1F2D;--slate:#3D5163;--mid:#7A95A6;
  --light:#F4F7F9;--white:#FFFFFF;--border:#DDE5EA;
  --green:#00C48C;--amber:#F59E0B;
}
main#MainContent {
    padding: 50px 0;
}
.wrap{max-width:680px;margin:0 auto;}
.header{text-align:center;margin-bottom:24px;}
.header-logo{font-size:22px;font-weight:700;color:var(--navy);letter-spacing:.04em;margin-bottom:4px;}
.header-sub{font-size:13px;color:var(--mid);}
.card{background:var(--white);border-radius:14px;border:1px solid var(--border);overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.07);}

.prog-bar{height:4px;background:var(--border);}
.prog-fill{height:100%;background:var(--teal);border-radius:2px;transition:width .4s ease;}

/* EMAIL GATE */
.email-gate{padding:40px 32px;text-align:center;}
.gate-ico{width:56px;height:56px;border-radius:50%;background:var(--teal-l);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;}
.gate-ico i{font-size:26px;color:var(--teal);}
.gate-h{font-size:22px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;}
.gate-sub{font-size:13px;color:var(--mid);line-height:1.65;margin-bottom:28px;max-width:380px;margin-left:auto;margin-right:auto;}
.gate-form{display:flex;flex-direction:column;gap:10px;max-width:360px;margin:0 auto;}
.gate-input{height:46px;border:1px solid var(--border);border-radius:8px;padding:0 16px;font-size:13px;font-family:inherit;color:var(--navy);outline:none;transition:border-color .15s;}
.gate-input:focus{border-color:var(--teal);}
.gate-btn{height:46px;background:var(--teal);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;letter-spacing:.03em;transition:opacity .15s;}
.gate-btn:hover{opacity:.88;}
.gate-skip{font-size:11px;color:var(--mid);margin-top:10px;cursor:pointer;text-decoration:underline;}
.gate-skip:hover{color:var(--slate);}
.gate-privacy{font-size:10px;color:var(--mid);margin-top:8px;line-height:1.5;}

/* QUIZ */
.q-step{display:none;padding:32px;}
.q-step.active{display:block;}
.q-label{font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--mid);margin-bottom:8px;}
.q-text{font-size:20px;font-weight:500;line-height:1.3;margin-bottom:22px;color:var(--navy);}
.opts{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:22px;}
.opt{border:1px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;background:var(--white);text-align:left;display:flex;align-items:flex-start;gap:12px;transition:all .15s;}
.opt:hover{background:var(--light);border-color:var(--teal-m);}
.opt.sel{border:2px solid var(--teal);background:var(--teal-l);}
.opt-ico{width:34px;height:34px;border-radius:8px;background:var(--light);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.opt-ico i{font-size:17px;color:var(--teal);}
.opt.sel .opt-ico{background:var(--teal-m);}
.opt-t{font-size:13px;font-weight:500;margin-bottom:2px;color:var(--navy);}
.opt-d{font-size:11px;color:var(--mid);line-height:1.4;}
.opt.sel .opt-t{color:var(--teal-d);}
.nav-row{display:flex;align-items:center;justify-content:space-between;}
.back-b{font-size:13px;color:var(--mid);background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:4px;}
.back-b:hover{color:var(--navy);}
.next-b{background:var(--teal);color:#fff;border:none;border-radius:22px;padding:11px 26px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity .15s;}
.next-b:disabled{opacity:.35;cursor:default;}
.next-b:not(:disabled):hover{opacity:.88;}

/* RESULTS */
.results{display:none;padding:32px;}
.results.active{display:block;}
.pair-wrap{display:grid;grid-template-columns:1fr auto 1fr;border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:18px;}
.primary-card{background:var(--navy);padding:22px;}
.p-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--green);margin-bottom:12px;display:flex;align-items:center;gap:5px;}
.p-img{height:120px;background:rgba(255,255,255,.07);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;overflow:hidden;}
.p-img img{max-height:110px;max-width:90%;object-fit:contain;}
.p-name{font-size:13px;font-weight:500;color:#fff;line-height:1.3;margin-bottom:5px;}
.p-price{font-size:16px;font-weight:500;color:var(--green);margin-bottom:8px;}
.p-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px;}
.p-tag{font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(0,196,140,.15);color:var(--green);border:0.5px solid rgba(0,196,140,.3);}
.p-why{font-size:11px;color:rgba(255,255,255,.5);line-height:1.5;margin-bottom:14px;}
.add-p{width:100%;background:var(--teal);color:#fff;border:none;border-radius:20px;padding:10px;font-size:12px;font-weight:600;cursor:pointer;}
.add-p:hover{background:var(--teal-d);}
.div-col{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 4px;background:var(--light);}
.plus-c{width:30px;height:30px;border-radius:50%;background:var(--white);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;}
.plus-c i{font-size:14px;color:var(--mid);}
.div-line{flex:1;width:0.5px;background:var(--border);}
.addon-card{background:var(--white);padding:22px;}
.a-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-bottom:12px;display:flex;align-items:center;gap:5px;}
.a-img{height:120px;background:var(--light);border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;overflow:hidden;}
.a-img img{max-height:110px;max-width:90%;object-fit:contain;}
.a-name{font-size:13px;font-weight:500;color:var(--navy);line-height:1.3;margin-bottom:5px;}
.a-price{font-size:16px;font-weight:500;color:var(--teal);margin-bottom:8px;}
.a-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px;}
.a-tag{font-size:10px;padding:2px 8px;border-radius:10px;background:var(--teal-l);color:var(--teal-d);border:0.5px solid var(--teal-m);}
.a-why{font-size:11px;color:var(--mid);line-height:1.5;margin-bottom:14px;}
.add-a{width:100%;border:1px solid var(--teal);border-radius:20px;padding:10px;font-size:12px;font-weight:500;color:var(--teal);background:transparent;cursor:pointer;}
.add-a:hover{background:var(--teal);color:#fff;}
.bundle-bar{background:var(--light);border:1px solid var(--border);border-radius:12px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
.b-ico{width:36px;height:36px;border-radius:8px;background:var(--white);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.b-ico i{font-size:18px;color:var(--teal);}
.b-h{font-size:13px;font-weight:500;color:var(--navy);margin-bottom:2px;}
.b-s{font-size:11px;color:var(--mid);}
.bp-was{font-size:11px;color:var(--mid);text-decoration:line-through;}
.bp-now{font-size:16px;font-weight:500;color:var(--teal);}
.bundle-btn{background:var(--navy);color:#fff;border:none;border-radius:20px;padding:10px 18px;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;}
.retake-row{display:flex;align-items:center;gap:10px;margin-bottom:24px;}
.retake-b{font-size:13px;color:var(--mid);background:none;border:1px solid var(--border);border-radius:16px;padding:8px 18px;cursor:pointer;}
.retake-b:hover{background:var(--light);}
.grid-sec{border-top:1px solid var(--border);padding-top:24px;}
.grid-sec-h{font-size:16px;font-weight:600;color:var(--navy);margin-bottom:3px;}
.grid-sec-s{font-size:12px;color:var(--mid);margin-bottom:14px;}
.fpills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;}
.fp{font-size:11px;padding:5px 12px;border-radius:12px;border:1px solid var(--border);cursor:pointer;background:var(--white);color:var(--mid);transition:all .15s;}
.fp:hover{background:var(--light);}
.fp.on{background:var(--navy);color:#fff;border-color:var(--navy);}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:10px;}
.pc{border:1px solid var(--border);border-radius:12px;overflow:hidden;background:var(--white);transition:border-color .15s;}
.pc:hover{border-color:var(--teal-m);}
.pc.hi{border:2px solid var(--teal);}
.pc.hidden{display:none;}
.pi{height:90px;background:var(--light);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.pi img{max-height:82px;max-width:88%;object-fit:contain;}
.pc-badge{position:absolute;top:5px;left:5px;font-size:9px;padding:2px 6px;border-radius:8px;font-weight:600;color:#fff;}
.pb{padding:9px 10px 11px;}
.pn{font-size:11px;font-weight:500;margin-bottom:3px;line-height:1.35;color:var(--navy);}
.pp{font-size:12px;font-weight:500;color:var(--teal);margin-bottom:6px;}
.pbens{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:8px;}
.pben{font-size:9px;padding:1px 5px;border-radius:8px;background:var(--teal-l);color:var(--teal-d);border:0.5px solid var(--teal-m);}
.padd{width:100%;border:1px solid var(--border);border-radius:10px;padding:5px;font-size:11px;color:var(--mid);background:transparent;cursor:pointer;transition:all .15s;}
.padd:hover{border-color:var(--teal);color:var(--teal);}
.pc.dimmed{opacity:.5;}
.pc.dimmed .padd{cursor:default;}
</style>
