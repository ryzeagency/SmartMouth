function startQuiz() {
  const emailInput = document.getElementById('email-input');
  emailCaptured = emailInput ? emailInput.value.trim() : '';
  document.getElementById('email-gate').style.display = 'none';
  document.getElementById('prog').style.width = '20%';
  goTo(1);
}

function pick(el) {
  const q = el.dataset.q;
  document.querySelectorAll(`.opt[data-q="${q}"]`).forEach(b=>b.classList.remove('sel'));
  el.classList.add('sel');
  ans[q] = el.dataset.v;
  document.getElementById('n'+q).disabled = false;
}

function goTo(n) {
  document.querySelectorAll('.q-step').forEach(s=>s.classList.remove('active'));
  document.getElementById('q'+n).classList.add('active');
  document.getElementById('prog').style.width=(n*20)+'%';
  window.scrollTo({top:0,behavior:'smooth'});
}

function scoreP(p) {
  if (!p.inStock) return -99;
  let s = 0;
  if (p.concern.includes(ans[1])) s += 6;
  if (p.duration && p.duration.includes(ans[2])) s += 3;
  // Duration boosts clinical/liposomal for long-term issues
  if ((ans[2]==='years'||ans[2]==='months') && (p.cat==='liposomal'||p.benefits.some(b=>b.includes('Clinical')))) s += 2;
  if (p.lifestyle && p.lifestyle.includes(ans[3])) s += 2;
  if ((ans[3]==='medication') && p.concern.includes('dry')) s += 3;
  if ((ans[3]==='smoker') && (p.cat==='liposomal'||p.benefits.some(b=>b.includes('Clinical')))) s += 2;
  // Location scoring
  if (ans[4]==='travel' && p.cat==='travel') s += 5;
  if (ans[4]==='travel' && p.cat==='mints') s += 3;
  if ((ans[4]==='both'||ans[4]==='work') && (p.cat==='travel'||p.cat==='mints')) s += 2;
  if (ans[4]==='home' && (p.cat==='mouthwash'||p.cat==='liposomal')) s += 1;
  // Experience scoring — strongest filter
  if (ans[5]==='nothing_worked' && p.cat==='liposomal') s += 5;
  if (ans[5]==='nothing_worked' && (p.id===2||p.id===5||p.id===3)) s += 3;
  if (ans[5]==='want_stronger' && (p.cat==='liposomal'||p.id===2||p.id===10)) s += 4;
  if (ans[5]==='new_to_mouthwash' && (p.id===1||p.id===3||p.id===4)) s += 4;
  if (ans[5]==='switching' && (p.cat==='liposomal'||p.id===2)) s += 3;
  return s;
}

function pickAddon(primary) {
  const concern = ans[1], location = ans[4];
  const cands = products.filter(p => {
    if (!p.inStock) return false;
    if (p.id === primary.id) return false;
    if (p.cat === primary.cat && p.cat !== 'toothpaste') return false;
    return p.addonFor.includes(concern);
  });
  if (!cands.length) return products.find(p=>p.id===11&&p.inStock) || products.find(p=>p.inStock&&p.id!==primary.id);
  const sc = cands.map(p => {
    let s = 0;
    if (p.addonFor.includes(concern)) s += 3;
    if ((location==='travel'||location==='both'||location==='work') && p.cat==='travel') s += 3;
    if ((location==='travel'||location==='work') && p.cat==='mints') s += 2;
    if (p.cat==='toothpaste') s += 2;
    if (concern==='dry' && p.cat==='mints') s += 3;
    return {p, s};
  });
  sc.sort((a,b)=>b.s-a.s);
  return sc[0].p;
}

function fmt(n){return'$'+n.toFixed(2);}

function showResults() {
  document.querySelectorAll('.q-step').forEach(s=>s.classList.remove('active'));
  document.getElementById('prog').style.width='100%';
  document.getElementById('results').classList.add('active');

  const sorted = products.map(p=>({...p,sc:scoreP(p)})).sort((a,b)=>b.sc-a.sc);
  const primary = sorted[0];
  const addon = pickAddon(primary);

  document.getElementById('pcard').innerHTML=`
    <div class="p-label"><i class="ti ti-crown" style="font-size:12px;"></i> Primary formula</div>
    <div class="p-img"><img src="${PRODUCT_IMGS[String(primary.id)]||''}" alt="${primary.name}" loading="lazy"/></div>
    <div class="p-name">${primary.name}</div>
    <div class="p-price">${fmt(primary.priceN)}</div>
    <div class="p-tags">${primary.benefits.map(b=>`<span class="p-tag">${b}</span>`).join('')}</div>
    <div class="p-why">${primaryReasons[primary.id]||'Matched to your answers for maximum effectiveness.'}</div>
    <button class="add-p">Add to cart</button>`;

  document.getElementById('acard').innerHTML=`
    <div class="a-label"><i class="ti ti-sparkles" style="font-size:12px;"></i> Recommended add-on</div>
    <div class="a-img"><img src="${PRODUCT_IMGS[String(addon.id)]||''}" alt="${addon.name}" loading="lazy"/></div>
    <div class="a-name">${addon.name}</div>
    <div class="a-price">${fmt(addon.priceN)}</div>
    <div class="a-tags">${addon.benefits.map(b=>`<span class="a-tag">${b}</span>`).join('')}</div>
    <div class="a-why">${addonReasons[addon.id]||'A great complement to your primary formula.'}</div>
    <button class="add-a">Add to cart</button>`;

  const total = primary.priceN + addon.priceN;
  const save = total * 0.10;
  document.getElementById('bwas').textContent = fmt(total);
  document.getElementById('bnow').textContent = fmt(total-save)+' (save '+fmt(save)+')';
  document.getElementById('bsub').textContent = primary.name.split(' ').slice(0,3).join(' ')+' + '+addon.name.split(' ').slice(0,3).join(' ')+' — 10% off together';

  renderGrid(primary.id, addon.id);
  window.scrollTo({top:0,behavior:'smooth'});
}

function retake() {
  Object.keys(ans).forEach(k=>delete ans[k]);
  document.querySelectorAll('.opt').forEach(b=>b.classList.remove('sel'));
  document.querySelectorAll('.next-b').forEach(b=>b.disabled=true);
  document.getElementById('results').classList.remove('active');
  document.getElementById('email-gate').style.display='block';
  document.getElementById('prog').style.width='0%';
  window.scrollTo({top:0,behavior:'smooth'});
}

function renderGrid(pid, aid) {
  const grid = document.getElementById('pgrid');
  grid.innerHTML = '';
  products.forEach(p => {
    const isM = (p.id===pid||p.id===aid);
    const card = document.createElement('div');
    card.className = 'pc'+(isM?' hi':'')+(p.inStock?'':' dimmed');
    card.dataset.cat = p.cat;
    card.innerHTML=`
      <div class="pi">
        <img src="${PRODUCT_IMGS[String(p.id)]||''}" alt="${p.name}" loading="lazy"/>
        ${isM?`<span class="pc-badge" style="background:${p.id===pid?'var(--teal)':'var(--amber)'};">${p.id===pid?'Your pick':'Add-on'}</span>`:''}
        ${!p.inStock?'<span class="pc-badge" style="background:#aaa;">Sold out</span>':''}
      </div>
      <div class="pb">
        <div class="pn">${p.name}</div>
        <div class="pp">${p.price}</div>
        <div class="pbens">${p.benefits.slice(0,2).map(b=>`<span class="pben">${b}</span>`).join('')}</div>
        <button class="padd" ${p.inStock?'':'disabled'}>${p.inStock?'Add to cart':'Out of stock'}</button>
      </div>`;
    grid.appendChild(card);
  });
}

function fg(el, cat) {
  document.querySelectorAll('.fp').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');
  document.querySelectorAll('.pc').forEach(c=>{
    c.classList.toggle('hidden', cat!=='all' && c.dataset.cat!==cat);
  });
}

// Allow enter key on email input
document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('email-input');
  if (input) input.addEventListener('keydown', e => { if(e.key==='Enter') startQuiz(); });
});
