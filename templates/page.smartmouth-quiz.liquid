      </div>
      <div class="nav-row"><button class="back-b" onclick="goTo(1)"><i class="ti ti-arrow-left"></i> Back</button><button class="next-b" id="n2" disabled onclick="goTo(3)">Next <i class="ti ti-arrow-right"></i></button></div>
