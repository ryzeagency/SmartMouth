    "how_to_sulfur_gas_CEhCNc": {
      "type": "how-to-sulfur-gas",
      "blocks": {
        "card_riTqj7": {
          "type": "card",
          "settings": {
            "heading": "The problem",
            "emphasis": "Germs + Protein in Your Saliva = Sulfur Gas",
            "body": "<p>Bacteria in your mouth break down protein particles in your saliva — producing sulfur compounds that are detectable by the human nose even at a few parts per billion. That’s bad breath. And it’s a process that never stops on its own.</p>",
            "background_color": "#bfe5de"
          }
        },
        "card_fbn8Qn": {
          "type": "card",
          "settings": {
            "heading": "The Solution",
            "emphasis": "Germs + SmartMouth™ Zinc Ions = No More Bad Breath",
            "body": "<p>When SmartMouth™’s two solutions combine, billions of zinc ions are released. They bond to germs and block them from producing sulfur gas entirely — eliminating bad breath instantly and preventing it from returning for 24 hours.</p>",
            "background_color": "#d2e4f5"
          }
        }
      },
      "block_order": [
        "card_riTqj7",
        "card_fbn8Qn"
      ],
      "name": "How To Sulfur Gas",
